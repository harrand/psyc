test : func(-> v0)
{
	fn1 : x64val mut;
	x64_add_func(ref fn1);
	
	inst : x64inst mut;
	[inst.operands # 2] = zero;

	inst.tag = x64inst_tag.mov;
	op0 ::= inst.operands # 0;
	op0->tag = x64val_tag.reg;
	[x64val_reg_get_reg(op0)] = x64_reg.r8;
	[x64val_reg_get_size(op0)] = 64;

	op1 ::= inst.operands # 1;
	op1->tag = x64val_tag.memreg;
	[x64val_memreg_get_size(op1)] = 64;
	[x64val_memreg_get_base(op1)] = x64_reg.rax;
	[x64val_memreg_get_base_size(op1)] = 64;
	[x64val_memreg_get_index(op1)] = x64_reg.rdx;
	[x64val_memreg_get_index_size(op1)] = 32;
	[x64val_memreg_get_scale(op1)] = 0;
	[x64val_memreg_get_displacement(op1)] = 1024;
	[x64val_memreg_get_displacement_size(op1)] = 32;
	x64_add_instruction(ref inst);

	inst.tag = x64inst_tag.syscall;
	[inst.operands # 0] = zero;
	[inst.operands # 1] = zero;
	x64_add_instruction(ref inst);

	// shared stream
	stream : bwriter mut;
	w ::= ref stream;
	bwriter_create_native(w, 1024, scratch_arena);

	// dump assembly
	x64prog_dump_to(w, ref(x64api.prog));
	putchars(w->buf, w->cursor);

	// dump encoding
	w->cursor = 0;
	meta : x64enc_meta mut;
	meta.begin_code_vaddr = 0;
	meta.begin_readonly_glob_vaddr = 0;
	meta.begin_mutable_glob_vaddr = 0;
	meta.begin_mutablezero_glob_vaddr = 0;
	x64prog_encode_to(w, ref(x64api.prog), ref meta);
	putchars(w->buf, w->cursor);
	// dump encoding to file
	f ::= path_open(zstr2path("build/test.bin\0"), file.cwd, file_access.write);
	file_write(f, w->buf, w->cursor);
	file_close(f);
};
