test : func(-> v0)
{
	fn1 : x64val mut;
	x64_add_func(ref fn1);
	
	inst : x64inst mut;
	[inst.operands # 2] = zero;

	inst.tag = x64inst_tag.mov;
	op0 ::= inst.operands # 0;
	op0->tag = x64val_tag.reg;
	[x64val_reg_get_reg(op0)] = x64_reg.rax;
	[x64val_reg_get_size(op0)] = 64;

	op1 ::= inst.operands # 1;
	op1->tag = x64val_tag.memreg;
	[x64val_memreg_get_size(op1)] = 64;
	[x64val_memreg_get_base(op1)] = x64_reg.rax;
	[x64val_memreg_get_base_size(op1)] = 64;
	[x64val_memreg_get_index(op1)] = x64_reg.rdx;
	[x64val_memreg_get_index_size(op1)] = 32;
	[x64val_memreg_get_scale(op1)] = 0;
	[x64val_memreg_get_displacement(op1)] = 1024;
	[x64val_memreg_get_displacement_size(op1)] = 32;
	x64_add_instruction(ref inst);

	inst.tag = x64inst_tag.syscall;
	[inst.operands # 0] = zero;
	[inst.operands # 1] = zero;
	x64_add_instruction(ref inst);

	x64_dump();
};
