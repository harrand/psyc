== default ==
{
	llvm();
};

== llvm ==
{
	add_build_file_with_config("../libpsyc.psy", "llvm");
};

== psyir ==
{
	add_build_file_with_config("../libpsyc.psy", "psyir");
};

main : func(args : program_args mut? -> s32)
{
	envp = (args->envp);
	setup_arenas();
	putchar(10);
	putchar(10);
	ret ::= test();
	putchar(10);
	putzstr("exit code: ");
	putuint(ret@_);
	putzstr("
");
	psyc_set_stage(psyc_stage.build);
	if(ret != 0)
	{
		psyc_error_begin(zero);
		putzstr("detected that test has failed");
		psyc_diag_end();
		psyc_exit_failure();
	}
	putchar(10);
	return ret;
};

