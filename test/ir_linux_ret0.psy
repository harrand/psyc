== default ==
{
	add_build_file_with_config("./_test_helper.psy", "psyir");

	executable("ir_linux_ret0");
	postbuild_command("(cd build && ./ir_linux_ret0)");
};

test : func(-> s32)
{
	testglobdata : u64 := 0x12345678;
	testglob ::= ir_add_glob(ref testglobdata, sizeof typeof(testglobdata), false);

	main_return : irsz := irsz.d;
	ir_add_func(irabi.psy, zero, zero, ref main_return, 1);
	stackvar ::= ir_stack(irval_dimm(64), irval_dimm(1), zero);
	ir_ret1(ir_load(irsz.d, testglob, zero, irval_qimm(1), zero), zero);
	ir_ret1(ir_load(irsz.d, stackvar, zero, irval_qimm(1), zero), zero);

	teststream ::= bwriter mut
	{
		.endian := native_endianness();
		.buf := zero;
		.len := zero;
		.cursor := zero;
		.ar := global_arena;
	};

	bwrite_ir(ref teststream);
	putbytes(teststream.buf, teststream.cursor);

	ir_lower_x64();

	teststream.cursor = 0;
	x64_dump_disasm_to(ref teststream);
	putbytes(teststream.buf, teststream.cursor);

	// write out the elf.
	encode_basic_elf("./generated_ir_linux_ret0.elf", x64api.prog, 0);
	file_ensure_executable("./generated_ir_linux_ret0.elf");
	cmd ::= "./generated_ir_linux_ret0.elf";
	return sys_shell_command(cmd, zstrlen(cmd), envp, global_arena)@_;
};
