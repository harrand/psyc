== default ==
{
	add_build_file("../src/stdlib/stdlib.psy");
	add_source_directory("../src/backend/x64");
	add_source_directory("../src/backend/elf");
	add_source_file("../src/frontend/diag.psy");

	executable("x64_linux_helloworld");
	postbuild_command("(cd test/build && ./x64_linux_helloworld)");
	postbuild_command("test/build/generated_x64_linux_helloworld.elf ; echo exit code: $?");
};

global_arena_val : arena mut := zero;
global_arena : arena mut? mut := zero;

// stores strings
string_arena_val : arena mut := zero;
string_arena : arena mut? mut := zero;

setup_arenas : func( -> v0)
{
	global_arena_val = arena_create_virtual_reserve(arena_default_reserve, 4096 * 1024);
	global_arena = ref global_arena_val;
	arena_auto_align(global_arena, 8);

	string_arena_val = arena_create_virtual_reserve(arena_default_reserve, 4096 * 1024);
	string_arena = ref string_arena_val;
	arena_auto_align(string_arena, 1);
};

main : func(args : program_args mut? -> s32)
{
	setup_arenas();
	putchar(10);
	putchar(10);
	generate_helloworld_elf();
	putchar(10);
	return 0;
};

generate_helloworld_elf : func(-> v0)
{
	x64_add_func();
	// write(2, strlit, sizeof(strlit))
	helloworld_str ::= x64_add_rodata(x64g{.size := 12; .init_data := "hello world
"; .init_data_size := 12;});
	x64_mov(x64v_reg(x64_reg.rax, 64), x64v_imm(1, 32));
	x64_mov(x64v_reg(x64_reg.rdi, 64), x64v_imm(1, 32));
	x64_lea(x64v_reg(x64_reg.rsi, 64), x64v_rodata(helloworld_str, 0, 64));
	x64_mov(x64v_reg(x64_reg.rdx, 64), x64v_imm(12, 32));
	x64_syscall();

	// exit(0) (linux x64 syscall)
	x64_mov(x64v_reg(x64_reg.rax, 64), x64v_imm(60, 32));
	x64_mov(x64v_reg(x64_reg.rdi, 64), x64v_imm(1, 32));
	x64_syscall();

	teststream ::= bwriter mut
	{
		.endian := native_endianness();
		.buf := zero;
		.len := zero;
		.cursor := zero;
		.ar := global_arena;
	};

	x64_dump_disasm_to(ref teststream);
	putbytes(teststream.buf, teststream.cursor);

	// write out the elf.
	elf_path ::= "";
	encode_basic_elf("./generated_x64_linux_helloworld.elf", x64api.prog, 0);
	file_ensure_executable("./generated_x64_linux_helloworld.elf");
};
