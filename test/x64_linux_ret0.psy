== default ==
{
	add_build_file("./_test_helper.psy");
	add_source_directory("../src/backend/x64");
	add_source_directory("../src/backend/elf");

	executable("x64_linux_ret0");
	postbuild_command("(cd test/build && ./x64_linux_ret0)");
};

test : func(-> s32)
{
	x64_add_func();
	// exit(0) (linux x64 syscall)
	x64_mov(x64v_reg(x64_reg.rax, 64), x64v_imm(60, 32));
	x64_mov(x64v_reg(x64_reg.rdi, 64), x64v_imm(0, 32));
	x64_syscall();

	teststream ::= bwriter mut
	{
		.endian := native_endianness();
		.buf := zero;
		.len := zero;
		.cursor := zero;
		.ar := global_arena;
	};

	x64_dump_disasm_to(ref teststream);
	putbytes(teststream.buf, teststream.cursor);

	// write out the elf.
	encode_basic_elf("./generated_x64_linux_ret0.elf", x64api.prog, 0);
	file_ensure_executable("./generated_x64_linux_ret0.elf");
	cmd ::= "./generated_x64_linux_ret0.elf";
	return sys_shell_command(cmd, zstrlen(cmd), envp, global_arena)@_;
};
