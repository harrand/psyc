== default ==
{
	add_build_file_with_config("./_test_helper.psy", "psyir");

	executable("x64_linux_ret0");
	postbuild_command("(cd build && ./x64_linux_ret0)");
};

test : func(-> s32)
{
	x64_add_func();
	// exit(0) (linux x64 syscall)
	x64_mov(x64v_reg(x64_reg.rax, 64), x64v_imm(60, 32));
	//x64_mov(x64v_reg(x64_reg.rdi, 64), x64v_imm(0, 32));

	x64_mov(x64v_reg(x64_reg.rcx, 64), x64v_imm(6, 32));
	x64_cvtsi2ss(x64v_reg(x64_reg.rax, 128), x64v_reg(x64_reg.rcx, 64));
	x64_mulss(x64v_reg(x64_reg.rax, 128), x64v_reg(x64_reg.rax, 128));
	x64_cvttss2si(x64v_reg(x64_reg.rdi, 64), x64v_reg(x64_reg.rax, 128));
	x64_syscall();

	teststream ::= bwriter mut
	{
		.endian := native_endianness();
		.buf := zero;
		.len := zero;
		.cursor := zero;
		.ar := global_arena;
	};

	x64_dump_disasm_to(ref teststream);
	putbytes(teststream.buf, teststream.cursor);

	// write out the elf.
	encode_basic_elf_x64("./generated_x64_linux_ret0.elf", ref(x64api.prog));
	file_ensure_executable("./generated_x64_linux_ret0.elf");
	cmd ::= "./generated_x64_linux_ret0.elf";
	return sys_shell_command(cmd, zstrlen(cmd), envp, global_arena)@_;
};
