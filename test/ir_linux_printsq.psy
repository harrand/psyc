== default ==
{
	add_build_file_with_config("./_test_helper.psy", "psyir");

	executable("ir_linux_printsq");
	postbuild_command("(cd build && ./ir_linux_printsq)");
};

test : func(-> s32)
{
	write_syscall_params ::= irsz[3]{.0 := irsz.q; .1 := irsz.q; .2 := irsz.q;};
	write_syscall_constraint ::= "={rax},0,{rdi},{rsi},{rdx},~{rcx},~{r11},~{memory}";
	write_syscall_code ::= "mov rax, 1
mov rdi, $0
mov rsi, $1
mov rdx, $2
syscall";
	write_syscall ::= ir_add_asm(write_syscall_params # 0, countof typeof(write_syscall_params), zero, write_syscall_constraint, zstrlen(write_syscall_constraint), write_syscall_code, zstrlen(write_syscall_code));

	// putbyte : func(chars : u8?, count : u64 -> v0)
	ir_putbytes ::= ir_add_empty_func(irabi.psy);

	ir_putbytes_chars ::= ir_add_param(irsz.q);
	ir_putbytes_count ::= ir_add_param(irsz.q);
	ir_putbytes_underlying_call_params ::= irval[3]
	{
		.0 := irval_dimm(1);
		.1 := ir_putbytes_chars;
		.2 := ir_putbytes_count;
	};
	ir_call_asm(write_syscall, ir_putbytes_underlying_call_params # 0, countof typeof(ir_putbytes_underlying_call_params), zero);
	ir_ret0(zero);

	helloworld_strlen ::= 12;
	helloworld_str ::= ir_add_glob("hello world
", helloworld_strlen, false);

	ir_putuint ::= ir_add_empty_func(irabi.psy);
	ir_putuint_v ::= ir_add_param(irsz.q);
	i_is_two_digits ::= ir_cmp_ugt(ir_putuint_v, irval_qimm(9), zero);

	true_blk ::= ir_add_blk();
	false_blk ::= ir_add_blk();
	
	ir_set_pos(ir_putuint);
	ir_jmpif0(i_is_two_digits, true_blk, false_blk, zero);

	ir_set_pos(true_blk);
	recursive_call_params ::= ir_udiv(ir_putuint_v, irval_qimm(10), zero);
	ir_call_fn(ir_putuint, ref recursive_call_params, 1, zero, zero);
	ir_jmp0(false_blk, zero);

	ir_set_pos(false_blk);
	paramptr ::= ir_stack(irval_qimm(1), irval_qimm(1), zero);
	digit ::= ir_sub(ir_putuint_v, ir_umul(ir_udiv(ir_putuint_v, irval_qimm(10), zero), irval_qimm(10), zero), zero);
	ir_store(ir_trunc(irsz.b, ir_add(irval_qimm('0'), digit, zero), zero), paramptr, zero, zero, zero, zero);
	putbytes_params ::= irval[2]
	{
		.0 := paramptr;
		.1 := irval_qimm(1);
	};
	ir_call_fn(ir_putbytes, putbytes_params # 0, countof typeof(putbytes_params), zero, zero);

	// main func
	ir_main ::= ir_add_empty_func(irabi.psy);
	putuint_call_params ::= irval[1]
	{
		.0 := irval_qimm(69);
	};
	ir_call_fn(ir_putuint, putuint_call_params # 0, countof typeof(putuint_call_params), zero, zero);

	exit_syscall_constraint ::= "={rax},0,{rdi},{rsi},~{rcx},~{r11},~{memory}";
	exit_syscall_code ::= "mov rax, 60
mov rdi, $0
syscall";
	exit_syscall ::= ir_add_asm(zero, zero, zero, exit_syscall_constraint, zstrlen(exit_syscall_constraint), exit_syscall_code, zstrlen(exit_syscall_code));
	exitcode ::= irval_dimm(0);
	ir_call_asm(exit_syscall, ref exitcode, 1, zero);

	ir_set_entrypoint(ir_main);

	teststream ::= bwriter mut
	{
		.endian := native_endianness();
		.buf := zero;
		.len := zero;
		.cursor := zero;
		.ar := global_arena;
	};

	bwrite_ir(ref teststream);
	putbytes(teststream.buf, teststream.cursor);

	ir_lower_x64();

	teststream.cursor = 0;
	x64_dump_disasm_to(ref teststream);
	putbytes(teststream.buf, teststream.cursor);

	// write out the elf.
	encode_basic_elf("./generated_ir_linux_printsq.elf", ref(x64api.prog));
	file_ensure_executable("./generated_ir_linux_printsq.elf");
	cmd ::= "./generated_ir_linux_printsq.elf";
	return sys_shell_command(cmd, zstrlen(cmd), envp, global_arena)@_;
};
