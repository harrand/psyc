wv : bwriter mut := zero;
w : bwriter mut? mut := zero;
irtest : func(-> v0)
{
	irtest_begin();

	testval ::= irval_reg(0, tyid.u64);
	bwrite_irval(w, testval);

	irtest_end();
};

irtest_begin : func(-> v0)
{
	wv = bwriter mut
	{
		.ar := global_arena;
		... := zero;
	};
	w = ref wv;
};

irtest_end : func(-> v0)
{
	putchar(10);
	putzstr("ir:");
	putchar(10);
	putbytes(w->buf, w->cursor);

	putchar(10);
	putchar(10);
};
