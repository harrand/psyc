val_tag : enum
{
	// not a valid value (no data)
	.invalid := 0;
	// a type with no value (d0 = type)
	.typeonly := 1;
	// a value of 'zero' with no type (no data)
	.zerovalue := 2;
	// a scalar literal known at compile time (d0 = integer/floating-point)
	.scalar_literal := 3;
	// a string literal (d0 = data u8?, d1 = len)
	.string_literal := 4;
	// an aggregate (struct/array) literal known at compile time (d0 = pointer to val? members, must be size == ty_countof(type))
	.aggregate_literal := 5;
	// a pointer literal known at compile time (d0 = address)
	.pointer_literal := 6;
	// a reference to a function (d0 = function_t mut?)
	.function_reference := 7;
	// a reference to a variable (d0 = variable_t mut?)
	.variable_reference := 8;
	// a reference to an assembly (d0 = assembly_t mut?)
	.assembly_reference := 9;
	// a runtime scalar value (d0 = irval (d1, d2, d3 etc... are a part of the irval object and the rest of the val struct is assumed to be large enough to store the whole thing))
	.scalar := 10;
	// similar to scalar, but the irval stores a pointer to the value instead of the value directly (d0 = irval (d1, d2, d3 etc... are a part of the irval object and the rest of the val struct is assumed to be large enough to store the whole thing))
	.pointer := 11;
	// a bunch of irvals representing a complex value such as a struct value (d0 = member irvals?, d1 = count of members. remember this isnt necessarily the number of members of the struct)
	.aggregate := 12;
};

val : struct
{
	tag : val_tag;
	// datapoint 0 - use depends on tag
	d0 : u64;
	// datapoint 1 - use depends on tag
	d1 : u64;
	// datapoint 2 - use depends on tag
	d2 : u64;
	// datapoint 3 - use depends on tag
	d3 : u64;
	// datapoint 4 - use depends on tag
	d4 : u64;
	// type
	type : ty;
};

val_is_known_at_compile_time : func(v : val mut? -> bool)
{
	t ::= v->tag;
	return (t == val_tag.typeonly)
		|| (t == val_tag.zerovalue)
		|| (t == val_tag.scalar_literal)
		|| (t == val_tag.string_literal)
		|| (t == val_tag.aggregate_literal)
		|| (t == val_tag.pointer_literal)
		|| (t == val_tag.function_reference)
		|| (t == val_tag.variable_reference)
		|| (t == val_tag.assembly_reference);
};

val_get_type : func(v : val mut? -> ty mut?)
{
	return ref(v->type);
};

val_scalar_literal_get_integer : func(v : val mut? -> s64 mut?)
{
	return ref(v->d0)@s64 mut?;
};

val_scalar_literal_get_floating_point : func(v : val mut? -> f64 mut?)
{
	return ref(v->d0)@f64 mut?;
};

val_string_literal_get_data : func(v : val mut? -> u8 mut? mut?)
{
	return ref(v->d0)@u8 mut? mut?;
};

val_string_literal_get_length : func(v : val mut? -> u64 mut?)
{
	return ref(v->d1)@u64 mut?;
};

val_aggregate_literal_get_members : func(v : val mut? -> val mut?)
{
	return ref(v->d0)@val mut?;
};

// remember the members count is decided by the type and is thus *not* stored separately
val_aggregate_literal_get_members_count : func(v : val mut? -> u64)
{
	return ty_countof([val_get_type(v)]);
};

val_pointer_literal_get_address : func(v : val mut? -> u64 mut?)
{
	return ref(v->d0)@u64 mut?;
};

val_function_reference_get_function : func(v : val mut? -> function_t mut? mut?)
{
	return ref(v->d0)@function_t mut? mut?;
};

val_variable_reference_get_variable : func(v : val mut? -> variable_t mut? mut?)
{
	return ref(v->d0)@variable_t mut? mut?;
};

val_assembly_reference_get_assembly : func(v : val mut? -> assembly_t mut? mut?)
{
	return ref(v->d0)@assembly_t mut? mut?;
};

// note HH: sizeof(val.d1->end) must be >= sizeof(irval) otherwise this will buffer overrun
val_scalar_get_irval : func(v : val mut? -> irval mut?)
{
	return ref(v->d0)@irval mut?;
};

val_pointer_get_irval : func(v : val mut? -> irval mut?)
{
	return ref(v->d0)@irval mut?;
};

val_aggregate_get_members : func(v : val mut? -> val mut? mut?)
{
	return ref(v->d0)@val mut? mut?;
};

val_aggregate_get_members_count : func(v : val mut? -> u64 mut?)
{
	return ref(v->d1)@u64 mut?;
};

val_resolve : enum
{
	.type_only := 0;
	.compiletime_only := 1;
	.runtime_only := 2;
	.any := 3;
};

// val operations

val_from_type : func(type : ty, out : val mut? -> v0)
{
	out->tag = val_tag.typeonly;
	[val_get_type(out)] = type;
};

val_from_node : func(node : ast mut?, out : val mut?, resolve : val_resolve, src : source -> v0)
{
	[val_from_node_tbl # (node->tag@s64)](node, out, resolve, src);
};

val_from_node_nyi : func(node : ast mut?, out : val mut?, resolve : val_resolve, src : source -> v0)
{
	panic_begin();
	putzstr("val_from_node NYI for codepath: \0");
	putchar('\n');
	ast_dump_one(node, zero, zero, 1);
	putzstr("from source \0");
	putsrc(src, node->src_beg@u64, node->src_end@u64, putcol.blue_underline);
	panic_end();
};

val_from_node_expr : func(node : ast mut?, out : val mut?, resolve : val_resolve, src : source -> v0)
{
	[val_from_node_expr_tbl # ([ast_expr_get_tag(node)])@s64](node, out, resolve, src);
};

val_from_node_expr_nyi : func(node : ast mut?, out : val mut?, resolve : val_resolve, src : source -> v0)
{
	panic_begin();
	putzstr("val_from_node_expr NYI for codepath: \0");
	putchar('\n');
	ast_dump_one(node, zero, zero, 1);
	putzstr("from source \0");
	putsrc(src, node->src_beg@u64, node->src_end@u64, putcol.blue_underline);
	panic_end();
};

val_from_node_expr_literal : func(node : ast mut?, out : val mut?, resolve : val_resolve, src : source -> v0)
{
	[val_from_node_expr_literal_tbl # [ast_literal_get_tag(node)]@s64](node, out, resolve, src);
};

val_from_integer_literal : func(int : s64 weak, out : val mut? -> v0)
{
	out->tag = val_tag.scalar_literal;
	out->type = ty_integer_literal();
	[val_scalar_literal_get_integer(out)] = int;
};

val_from_node_expr_literal_integer : func(node : ast mut?, out : val mut?, resolve : val_resolve, src : source -> v0)
{
	val_from_integer_literal([ast_literal_get_integer(node)], out);
};

val_from_node_expr_literal_floating_point : func(node : ast mut?, out : val mut?, resolve : val_resolve, src : source -> v0)
{
	out->tag = val_tag.scalar_literal;
	[val_scalar_literal_get_floating_point(out)] = [ast_literal_get_floating_point(node)];
	out->type = ty_floating_point_literal();
};

val_from_node_expr_literal_char : func(node : ast mut?, out : val mut?, resolve : val_resolve, src : source -> v0)
{
	out->tag = val_tag.scalar_literal;
	[val_scalar_literal_get_integer(out)] = [ast_literal_get_char(node)]@s64;
	out->type = ty_floating_point_literal();
};

val_from_node_expr_literal_nyi : func(node : ast mut?, out : val mut?, resolve : val_resolve, src : source -> v0)
{
	panic_begin();
	putzstr("val_from_node_expr_literal NYI for codepath: \0");
	putchar('\n');
	ast_dump_one(node, zero, zero, 1);
	putzstr("from source \0");
	putsrc(src, node->src_beg@u64, node->src_end@u64, putcol.blue_underline);
	panic_end();
};

val_from_node_expr_blkinit : func(node : ast mut?, out : val mut?, resolve : val_resolve, src : source -> v0)
{
	typename_node ::= ast_blkinit_get_typename(node);
	type ::= ty_from_typename_node(typename_node, src);
	if(type == ty.invalid)
	{
		err_begin();
		putzstr("cannot decipher type of block-initialiser \0");
		putsrc(src, typename_node->src_beg@u64, typename_node->src_end@u64, putcol.red_underline);
		err_end();
	}
	if(resolve == val_resolve.type_only)
	{
		val_from_type(type, out);
		return;
	}
	panic_begin();
	putzstr("todo: val_from_node_expr_blkinit (type: \0");
	putty(type);
	putzstr(")\0");
	panic_end();
};

val_from_node_expr_countof : func(node : ast mut?, out : val mut?, resolve : val_resolve, src : source -> v0)
{
	typename_node ::= ast_countof_get_operand(node);
	val_from_integer_literal(ty_countof(ty_from_typename_node(typename_node, src)), out);
};

val_from_node_expr_typeof : func(node : ast mut?, out : val mut?, resolve : val_resolve, src : source -> v0)
{
	expr_node ::= ast_countof_get_operand(node);
	val_from_node(expr_node, out, val_resolve.type_only, src);
};

val_from_node_tbl ::= typeof(val_from_node)[countof ast_tag]
{
	.0 := val_from_node_nyi;
	.1 := val_from_node_nyi;
	.2 := val_from_node_expr;
	.3 := val_from_node_nyi;
	.4 := val_from_node_nyi;
	.5 := val_from_node_nyi;
	.6 := val_from_node_nyi;
	.7 := val_from_node_nyi;
	.8 := val_from_node_nyi;
	.9 := val_from_node_nyi;
	.10 := val_from_node_nyi;
	.11 := val_from_node_nyi;
	.12 := val_from_node_nyi;
	.13 := val_from_node_nyi;
	.14 := val_from_node_nyi;
	.15 := val_from_node_nyi;
	.16 := val_from_node_nyi;
	.17 := val_from_node_nyi;
	.18 := val_from_node_nyi;
	.19 := val_from_node_nyi;
};

val_from_node_expr_tbl ::= typeof(val_from_node)[countof ast_expr_tag]
{
	.0 := val_from_node_expr_nyi;
	.1 := val_from_node_expr_literal;
	.2 := val_from_node_expr_nyi;
	.3 := val_from_node_expr_nyi;
	.4 := val_from_node_expr_nyi;
	.5 := val_from_node_expr_nyi;
	.6 := val_from_node_expr_blkinit;
	.7 := val_from_node_expr_nyi;
	.8 := val_from_node_expr_nyi;
	.9 := val_from_node_expr_nyi;
	.10 := val_from_node_expr_nyi;
	.11 := val_from_node_expr_nyi;
	.12 := val_from_node_expr_countof;
	.13 := val_from_node_expr_typeof;
};

val_from_node_expr_literal_tbl ::= typeof(val_from_node)[countof ast_literal_tag]
{
	.0 := val_from_node_expr_literal_integer;
	.1 := val_from_node_expr_literal_floating_point;
	.2 := val_from_node_expr_literal_char;
	.3 := val_from_node_expr_literal_nyi;
	.4 := val_from_node_expr_literal_nyi;
};

