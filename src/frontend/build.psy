find_build_region : func(node : ast mut?, name : u8?, name_len : u64 -> ast mut?)
{
	i : u32 mut;
	count ::= node->children_count;
	for(i = 0; i < count; i = i + 1)
	{
		child ::= node->children # i;
		if((child->tag == ast_tag.stmt) && ([ast_stmt_get_tag(child)] == ast_stmt_tag.region) && streql(name, name_len, [ast_region_get_name(child)], [ast_region_get_name_len(child)]))
		{
			return child;
		}
	}
	return zero;
};
