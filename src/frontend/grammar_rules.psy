rule_declfinalised_obrace2functionimpl : func(nodes : ast mut?, nodes_count : u64, out_result : grammar_result mut? -> v0)
{
	out_result->type = grammar_result_type.reduce;
	out_result->shift_or_delete_count = 1;
	out_result->delete_offset = 1;


	out ::= nodes # 0;
	out->tag = ast_tag.function;
	// fun fact: this happens to be a noop because they are the same thing.
	[ast_function_get_typename(out)] = [ast_decl_get_typename(out)];
	[ast_function_get_parse_state(out)] = ast_function_parse_state.impl;
	// we could in theory check this in the parser, but leaving it for the typechecker might make more sense.
	//if([ast_typename_get_tag([ast_function_get_typename(out)])] != ast_typename_tag.function)
	//{
	//}
};

