	symbol_node ::= nodes # 1;
	out ::= nodes # 0;
	out->tag = ast_tag.init;
	[ast_init_get_tag(out)] = ast_init_tag.symbol;
	[ast_init_get_parse_state(out)] = ast_init_parse_state.wip;
	[ast_init_get_symbol(out)] = parse_state.src->src # (symbol_node->src_beg);
	[ast_init_get_symbol_len(out)] = (symbol_node->src_end - symbol_node->src_beg)@u64;
};

rule_dot_number_init2initwip : func(nodes : ast mut?, nodes_count : u64, out_result : grammar_result mut? -> v0)
{
	out_result->type = grammar_result_type.reduce;
	out_result->shift_or_delete_count = 2;
	out_result->delete_offset = 1;

	number_node ::= nodes # 1;
	out ::= nodes # 0;
	out->tag = ast_tag.init;
	[ast_init_get_tag(out)] = ast_init_tag.integer;
	[ast_init_get_parse_state(out)] = ast_init_parse_state.wip;

	numparse : parseutil_number mut;
	parseutil_parse_number(parse_state.src->src # (out->src_beg), (out->src_end - out->src_beg)@u64, ref numparse);
	if(numparse.tag == parseutil_number_tag.integer)
	{
		[ast_init_get_integer(out)] = numparse.i;
	}
	if(numparse.tag == parseutil_number_tag.floating_point)
	{
		warn_begin();
		putzstr("numeric initialiser was floating-point. truncating to ");
		putchar('"');
		putsint(numparse.f@s64);
		putchar('"');
		warn_end();
		[ast_init_get_integer(out)] = numparse.f@s64;
	}
};

