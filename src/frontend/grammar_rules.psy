rule_typenamewip_qualx2typenamewip : func(nodes : ast mut?, nodes_count : u64, out_result : grammar_result mut? -> v0)
{
	out_result->type = grammar_result_type.reduce;
	out_result->shift_or_delete_count = 1;
	out_result->delete_offset = 1;

	qual_keyword_node ::= nodes # 1;
	keyword_qual ::= [ast_token_get_tag(qual_keyword_node)];

	out ::= nodes # 0;
	if(keyword_qual == token_tag.keyword_mut)
	{
		[ast_typename_get_quals(out)] = [ast_typename_get_quals(out)] | ty.qual_mut;
	}
	if(keyword_qual == token_tag.keyword_weak)
	{
		[ast_typename_get_quals(out)] = [ast_typename_get_quals(out)] | ty.qual_weak;
	}
	if(keyword_qual == token_tag.keyword_static)
	{
		[ast_typename_get_quals(out)] = [ast_typename_get_quals(out)] | ty.qual_static;
	}
};

rule_typenamewip_qmark2typenamewip : func(nodes : ast mut?, nodes_count : u64, out_result : grammar_result mut? -> v0)
{
	out_result->type = grammar_result_type.reduce;
	out_result->shift_or_delete_count = 1;
	out_result->delete_offset = 1;

	out ::= nodes # 0;
	// make a copy of out, set it as out's child
	// change out to be a pointery typename so the pointee was the old 'out' (add pointerness)
	outcpy ::= [out];
	out->children = zero;
	out->children_count = 0;
	out->children_cap = 0;
	ast_add_child(out, ref outcpy);
	[ast_typename_get_parse_state(out)] = ast_typename_parse_state.wip;
	[ast_typename_get_tag(out)] = ast_typename_tag.pointer;
};

