rule_assemblycoding_tokenx2assemblycoding : func(nodes : ast mut?, nodes_count : u64, out_result : grammar_result mut? -> v0)
{
	out_result->type = grammar_result_type.reduce;
	out_result->shift_or_delete_count = 1;
	out_result->delete_offset = 1;

	out ::= nodes # 0;
	token_node ::= nodes # 1;
	// check if we have only 1 child (there is no coding symbol)
	if(out->children_count == 1)
	{
		ast_add_child(out, token_node);
	}
	else
	{
		// extend the tokens length
		(out->children # 1)->src_end = token_node->src_end;
	}
};

