	[ast_typename_get_parse_state(out)] = ast_typename_parse_state.wip;
	[ast_typename_get_quals(out)] = zero;
	[ast_typename_get_basename(out)] = parse_state.src->src # (out->src_beg);
	[ast_typename_get_basename_len(out)] = (out->src_end - out->src_beg)@u64;
