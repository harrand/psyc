rule_symbol_col_init2declawaitinitexpr : func(nodes : ast mut?, nodes_count : u64, out_result : grammar_result mut? -> v0)
{
	out_result->type = grammar_result_type.reduce;
	out_result->shift_or_delete_count = 2;
	out_result->delete_offset = 1;

	out ::= nodes # 0;
	out->tag = ast_tag.decl;
	[ast_decl_get_parse_state(out)] = ast_decl_parse_state.awaitinitexpr;
	[ast_decl_get_name(out)] = parse_state.src->src # (out->src_beg);
	[ast_decl_get_name_len(out)] = (out->src_end - out->src_beg)@u64;

	// add a deduced typename as child
	col_node ::= nodes # 1;
	deduced_typename_node : ast mut := [col_node];
	deduced_typename_node.tag = ast_tag.typename;
	[ast_typename_get_parse_state(ref deduced_typename_node)] = ast_typename_parse_state.finalised;
	[ast_typename_get_tag(ref deduced_typename_node)] = ast_typename_tag.deduced;
	[ast_typename_get_quals(ref deduced_typename_node)] = zero;
	ast_add_child(out, ref deduced_typename_node);
};

