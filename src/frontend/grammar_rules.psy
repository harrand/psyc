rule_charlit2literalexpr : func(nodes : ast mut?, nodes_count : u64, out_result : grammar_result mut? -> v0)
{
	out_result->type = grammar_result_type.reduce;
	out_result->shift_or_delete_count = 0;
	out_result->delete_offset = 0;

	out ::= nodes # 0;
	out->tag = ast_tag.expr;
	[ast_expr_get_tag(out)] = ast_expr_tag.literal;
	[ast_literal_get_tag(out)] = ast_literal_tag.char;
	[ast_literal_get_char(out)] = parseutil_escape_char(parse_state.src->src # (out->src_beg), (out->src_end - out->src_beg)@u64);
};

rule_number2literalexpr : func(nodes : ast mut?, nodes_count : u64, out_result : grammar_result mut? -> v0)
{
	out_result->type = grammar_result_type.reduce;
	out_result->shift_or_delete_count = 0;
	out_result->delete_offset = 0;

	out ::= nodes # 0;
	out->tag = ast_tag.expr;
	[ast_expr_get_tag(out)] = ast_expr_tag.literal;
	numparse : parseutil_number mut;
	parseutil_parse_number(parse_state.src->src # (out->src_beg), (out->src_end - out->src_beg)@u64, ref numparse);
	if(numparse.tag == parseutil_number_tag.integer)
	{
		[ast_literal_get_tag(out)] = ast_literal_tag.integer;
		[ast_literal_get_integer(out)] = numparse.i;
	}
	if(numparse.tag == parseutil_number_tag.floating_point)
	{
		[ast_literal_get_tag(out)] = ast_literal_tag.floating_point;
		[ast_literal_get_floating_point(out)] = numparse.f;
	}
	if(numparse.tag == zero)
	{
		panic_begin();
		putzstr("parsing of numeric literal yields zero parseutil_number_tag\n\0");
		putsrc(parse_state.s, out->src_beg@u64, out->src_end@u64, putcol.red_underline);
		panic_end();
	}
	[ast_literal_get_integer(out)] = 0;
};

rule_exprx_oparen2callwip : func(nodes : ast mut?, nodes_count : u64, out_result : grammar_result mut? -> v0)
{
	out_result->type = grammar_result_type.reduce;
	out_result->shift_or_delete_count = 1;
	out_result->delete_offset = 1;


	out ::= nodes # 0;
	outcpy ::= [out];
	out->tag = ast_tag.call;
	[ast_call_get_parse_state(out)] = ast_call_parse_state.wip;

	ast_add_child(out, ref outcpy);
};

