semal : func(-> v0)
{
	i : u64 mut;
	for(i = 0; i < prog.global_scope.funcs_count; i = i + 1)
	{
		semal_fnsig(prog.global_scope.funcs # i);
	}
	for(i = 0; i < prog.global_scope.funcs_count; i = i + 1)
	{
		semal_fndef(prog.global_scope.funcs # i);
	}
};

semal_fnsig : func(fn : function mut? -> v0)
{
	fn->type = type_from_node(fn->node);
};

semal_fndef : func(fn : function mut? -> v0)
{
};
