shell_command : func(cmd_zstr : u8? -> s32)
{
	shell_argv : u8? mut[3];
	[shell_argv # 0] = "-c\0";
	[shell_argv # 1] = cmd_zstr;
	[shell_argv # 2] = zero;
	return proc_wait_for_exit(proc_create(zstr2path("/bin/sh\0"), file.cwd, shell_argv # 0, countof typeof(shell_argv), file.cwd, file.cwd, file.cwd, scratch_arena));
};
