srcloc : struct
{
	file : u8?;
	line : u64;
	col : u64;
};


colour_red : func(-> v0)
{
	ansi_esc_char : u8 mut;
	ansi_esc_char = 27;
	linux_write(1, ref ansi_esc_char, 1);
	linux_write(1, "[91m", 4);
};

colour_reset : func(-> v0)
{
	ansi_esc_char : u8 mut;
	ansi_esc_char = 27;
	linux_write(1, ref ansi_esc_char, 1);
	linux_write(1, "[0m", 3);
};

err_begin : func(loc : srcloc -> v0)
{
};

err_end : func(loc : srcloc -> v0)
{
};
