val : struct
{
	tag : val_tag;
	// type of the value (everything beyond the 'zero' keyword produces a valid type)
	type : tyid;
	// category is lvalue or rvalue
	category : val_category;

	// if tag == val_tag.compile_time, this stores the value of the thing at compile-time (now)
	s : sval;
	// if tag == val_tag.runtime, this stores the psyir-level value representation of the thing
	r : rval;
};

val_category : enum
{
	.lvalue := 0;
	.rvalue := 1;
};

val_tag : enum
{
	.compile_time := 1;
	.runtime := 2;
	.type_only := 3;
};

val_resolution : enum
{
	.type_only := 0;
	.compile_time_only := 1;
	.runtime_only := 2;
	.either := 3;
};

sval_tag : enum
{
	.zero_value := 1;
	.undefined := 2;
	.literal := 3;
	.array_literal := 4;
	.struct_literal := 5;
	.function_reference := 6;
	.variable_reference := 7;
	.assembly_reference := 8;
};

// this gets messy really easily so i am going to be *very* specific
sval : struct
{
	// tells you what we're representing. do *not* assuem if val.type is an array type that our sval will always be sval_tag.array_literal. it could be zero, or undefined.
	tag : sval_tag;
	// if tag == sval_tag.literal, this has all the info you need. you can assume the literal-tag logically matches up with what the val.type is.
	literal : ast_literal;
	// if tag == sval_tag.array_literal or struct_literal, these represent the array elements (or struct members in-order) respectively. members_count should always be equal to countof(val.type), but they could all be undefined.
	members : sval mut?;
	// how many things have i stored for you in members
	members_count : u64;
	// internal.
	members_cap : u64;
	// if tag == sval_tag.function_reference/variable_reference/assembly_reference, this represents a pointer to the underlying function/variable/assembly struct
	ptr : v0? weak;
};

rval_tag : enum
{
	// rval.v is the whole value
	.scalar := 1;
	// rval.v is a pointer to the value
	.ptr := 2;
	// rval.v ignored, the value is split into separate chunks (each in rval.members)
	.chunked := 3;
};

rval : struct
{
	tag : rval_tag;
	v : irval;
	members : rval mut?;
	members_chunks : irchunk mut?;
	members_count : u64;
	members_cap : u64;
};

val_from_node : func(node : ast mut?, s : scope mut?, r : val_resolution -> val)
{
	ret ::= val_from_node_inner(node, s, r);
	if(r == val_resolution.compile_time_only)
	{
		val_must_be_compile_time(ret, node);
	}
	if(r == val_resolution.runtime_only)
	{
		return val_ensure_runtime(ret, node);
	}
	return ret;
};
// given a node, get a value representation of it
// if type_only is true - the val will have a valid .type member but all other fields should be assumed to be undefined
val_from_node_inner : func(node : ast mut?, s : scope mut?, r : val_resolution -> val)
{
	if(ast_is_expr(node, ast_expr_tag.literal))
	{
		return val_from_literal(node->literal);
	}
	if(ast_is_expr(node, ast_expr_tag.symbol))
	{
		return val_from_symbol(node, s);
	}
	if(ast_is_expr(node, ast_expr_tag.call))
	{
		return val_from_call(node, s, r);
	}
	// todo: impl
	psyc_panic_begin(node);
	putzstr("reached end of val_from_node_inner");
	psyc_panic_end(node);
	return zero;
};

val_from_literal : func(literal : ast_literal -> val)
{
	ret ::= val mut
	{
		.tag := val_tag.compile_time;
		.category := val_category.rvalue;
		.s := sval{.tag := sval_tag.literal; .literal := literal;};
	};
	if(literal.tag == ast_literal_tag.integer)
	{
		ret.type = tyid_integral_literal();
	}
	if(literal.tag == ast_literal_tag.floating_point)
	{
		ret.type = tyid_floating_point_literal();
	}
	if(literal.tag == ast_literal_tag.char)
	{
		ret.type = tyid_char_literal();
	}
	if(literal.tag == ast_literal_tag.string)
	{
		ret.type = tyid_string_literal();
	}
	if(literal.tag == ast_literal_tag.boolean)
	{
		ret.type = tyid_bool_literal();
	}
	return ret;
};

val_from_integer_literal : func(int : s64 weak -> val)
{
	return val_from_literal(ast_literal{.tag := ast_literal_tag.integer; .integer := int;});
};

val_from_floating_point_literal : func(float : f64 weak -> val)
{
	return val_from_literal(ast_literal{.tag := ast_literal_tag.floating_point; .floating_point := float;});
};

val_from_char_literal : func(char : u8 weak -> val)
{
	return val_from_literal(ast_literal{.tag := ast_literal_tag.char; .char := char;});
};

val_from_string_literal : func(string : u8?, string_len : u64 -> val)
{
	return val_from_literal(ast_literal{.tag := ast_literal_tag.string; .string := string; .string_len := string_len;});
};

val_from_bool_literal : func(boolean : bool -> val)
{
	return val_from_literal(ast_literal{.tag := ast_literal_tag.boolean; .boolean := boolean;});
};

val_must_get_integer : func(v : val, source : ast mut? -> s64 weak)
{
	if(v.tag != val_tag.compile_time)
	{
		psyc_error_begin(source);
		putzstr("cannot statically retrieve literal.integer value from non-compile-time value");
		psyc_error_end(source);
	}
	if(v.s.tag == sval_tag.zero_value)
	{
		return 0;
	}
	if(v.s.tag == sval_tag.literal)
	{
		if(v.s.literal.tag == ast_literal_tag.integer)
		{
			return v.s.literal.integer;
		}
		psyc_error_begin(source);
		putzstr("cannot statically retrieve literal.integer value from literal.");
		putzstr(enumname(v.s.literal.tag));
		putzstr(" value");
		psyc_error_end(source);
	}
	psyc_error_begin(source);
	putzstr("cannot statically retrieve literal.integer value from non-literal ");
	putchar('"');
	putzstr(enumname(v.s.tag));
	putchar('"');
	putzstr(" value");
	psyc_error_end(source);
	return zero;
};

val_must_get_floating_point : func(v : val, source : ast mut? -> f64 weak)
{
	if(v.tag != val_tag.compile_time)
	{
		psyc_error_begin(source);
		putzstr("cannot statically retrieve literal.floating_point value from non-compile-time value");
		psyc_error_end(source);
	}
	if(v.s.tag == sval_tag.zero_value)
	{
		return 0.0;
	}
	if(v.s.tag == sval_tag.literal)
	{
		if(v.s.literal.tag == ast_literal_tag.floating_point)
		{
			return v.s.literal.floating_point;
		}
		psyc_error_begin(source);
		putzstr("cannot statically retrieve literal.floating_point value from literal.");
		putzstr(enumname(v.s.literal.tag));
		putzstr(" value");
		psyc_error_end(source);
	}
	psyc_error_begin(source);
	putzstr("cannot statically retrieve literal.floating_point value from non-literal ");
	putchar('"');
	putzstr(enumname(v.s.tag));
	putchar('"');
	putzstr(" value");
	psyc_error_end(source);
	return zero;
};

val_must_get_char : func(v : val, source : ast mut? -> u8)
{
	if(v.tag != val_tag.compile_time)
	{
		psyc_error_begin(source);
		putzstr("cannot statically retrieve literal.char value from non-compile-time value");
		psyc_error_end(source);
	}
	if(v.s.tag == sval_tag.zero_value)
	{
		return 0;
	}
	if(v.s.tag == sval_tag.literal)
	{
		if(v.s.literal.tag == ast_literal_tag.char)
		{
			return v.s.literal.char;
		}
		psyc_error_begin(source);
		putzstr("cannot statically retrieve literal.char value from literal.");
		putzstr(enumname(v.s.literal.tag));
		putzstr(" value");
		psyc_error_end(source);
	}
	psyc_error_begin(source);
	putzstr("cannot statically retrieve literal.char value from non-literal ");
	putchar('"');
	putzstr(enumname(v.s.tag));
	putchar('"');
	putzstr(" value");
	psyc_error_end(source);
	return zero;
};

val_from_symbol : func(symbol_node : ast mut?, s : scope mut? -> val)
{
	symbol ::= symbol_node->symbol;
	// firstly check function name
	maybe_function ::= scope_find_function_with_fallback(s, symbol);
	if(maybe_function != zero)
	{
		return val_function_reference(maybe_function);
	}

	maybe_variable ::= scope_find_variable_with_fallback(s, symbol);
	if(maybe_variable != zero)
	{
		return val_variable_reference(maybe_variable);
	}

	maybe_assembly ::= scope_find_assembly_with_fallback(s, symbol);
	if(maybe_assembly != zero)
	{
		return val_assembly_reference(maybe_assembly);
	}

	maybe_type ::= ty_find_by_name(symbol);
	if(maybe_type != zero)
	{
		return val
		{
			.tag := val_tag.type_only;
			.type := maybe_type;
		};
	}

	// todo: impl
	psyc_panic_begin(symbol_node);
	putzstr("reached end of val_from_symbol");
	psyc_panic_end(symbol_node);
	return zero;
};

val_from_call : func(call_node : ast mut?, s : scope mut?, r : val_resolution -> val)
{
	// callee must be some type of callable
	callee ::= val_from_node(ast_get_child(call_node, 0), s, r);
	callee_type ::= ty_unwrap(callee.type)->fn.return_type;
	if(!ty_is_fn(callee_type))
	{
		psyc_error_begin(call_node);
		putzstr("attempt to call non-callable ");
		putchar('"');
		putty(callee_type);
		putchar('"');
		psyc_error_end(call_node);
	}
	if(callee.tag == val_tag.type_only)
	{
		return val_from_type(callee_type);
	}
	return zero;
};

val_function_reference : func(fn : function mut? -> val)
{
	return val
	{
		.tag := val_tag.compile_time;
		.type := fn->type;
		.category := val_category.rvalue;
		.s := sval
		{
			.tag := sval_tag.function_reference;
			.ptr := fn;
		};
	};
};

val_variable_reference : func(var : variable mut? -> val)
{
	return val
	{
		.tag := val_tag.compile_time;
		.type := var->type;
		.category := val_category.lvalue;
		.s := sval
		{
			.tag := sval_tag.variable_reference;
			.ptr := var;
		};
	};
};

val_assembly_reference : func(as : assembly mut? -> val)
{
	return val
	{
		.tag := val_tag.compile_time;
		.type := as->type;
		.category := val_category.rvalue;
		.s := sval
		{
			.tag := sval_tag.assembly_reference;
			.ptr := as;
		};
	};
};

val_must_convert : func(from : val, to : tyid, source : ast mut? -> val)
{
	conv ::= ty_converts_to(from.type, to);

	if((conv != tyconv.yes) && (conv != tyconv.yes_needs_convert))
	{
		psyc_error_begin(source);
		putzstr("no valid conversion from ");
		putty(from.type);
		putzstr(" to ");
		if(conv == tyconv.no_cant_add_staticness)
		{
			putzstr(" (cannot add staticness)");
		}
		if(conv == tyconv.no_but_yes_with_weak)
		{
			putzstr(" (but an explicit conversion would work)");
		}
		psyc_error_end(source);
	}

	// todo: impl
	psyc_panic_begin(source);
	putzstr("reached end of val_must_convert");
	psyc_panic_end(source);
	return zero;
};

val_from_type : func(type : tyid -> val)
{
	return val
	{
		.tag := val_tag.type_only;
		.type := type;
	};
};

// given a val, if its an rval, error out. if its a sval, do nothing
val_must_be_compile_time : func(v : val, source : ast mut? -> v0)
{
	if(v.tag == val_tag.runtime)
	{
		psyc_error_begin(source);
		putzstr("value must be statically known in this context, but can only produce a value at runtime");
		psyc_error_end(source);
	}
};

// given a val, if its an rval, do nothing. if its a sval, convert it to an rval
val_ensure_runtime : func(v : val, source : ast mut? -> val)
{
	if(v.tag == val_tag.runtime)
	{
		return v;
	}
	if(v.tag == val_tag.type_only)
	{
		psyc_panic_begin(source);
		putzstr("call to val_ensure_runtime on a typeonly val representing the type ");
		putchar('"');
		putty(v.type);
		putchar('"');
		psyc_panic_end(source);
	}
	if(v.s.tag == sval_tag.literal)
	{
		if(v.s.literal.tag == ast_literal_tag.integer)
		{
			// integer literal -> runtime value
			return val
			{
				.tag := val_tag.runtime;
				.category := val_category.rvalue;
				.r := rval
				{
					.tag := rval_tag.scalar;
					.v := irval_qimm(v.s.literal.integer);
				};
			};
		}
		if(v.s.literal.tag == ast_literal_tag.floating_point)
		{
			// floating-point literal -> runtime value
			return val
			{
				.tag := val_tag.runtime;
				.category := val_category.rvalue;
				.r := rval
				{
					.tag := rval_tag.scalar;
					.v := irval_ffimm(v.s.literal.floating_point);
				};
			};
		}
		if(v.s.literal.tag == ast_literal_tag.char)
		{
			// floating-point literal -> runtime value
			return val
			{
				.tag := val_tag.runtime;
				.category := val_category.rvalue;
				.r := rval
				{
					.tag := rval_tag.scalar;
					.v := irval_bimm(v.s.literal.char);
				};
			};
		}
		if(v.s.literal.tag == ast_literal_tag.string)
		{
			// string literal -> runtime value
			return val
			{
				.tag := val_tag.runtime;
				.category := val_category.rvalue;
				.r := rval
				{
					.tag := rval_tag.scalar;
					.v := ir_add_glob(v.s.literal.string, v.s.literal.string_len, false);
				};
			};
		}
		if(v.s.literal.tag == ast_literal_tag.boolean)
		{
			// floating-point literal -> runtime value
			return val
			{
				.tag := val_tag.runtime;
				.category := val_category.rvalue;
				.r := rval
				{
					.tag := rval_tag.scalar;
					.v := irval_bimm(v.s.literal.boolean);
				};
			};
		}
	}
	psyc_panic_begin(source);
	putzstr("reached end of val_ensure_runtime");
	psyc_panic_end(source);
	return zero;
};
