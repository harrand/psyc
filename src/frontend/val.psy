val : struct
{
	tag : val_tag;
	// type of the value (everything beyond the 'zero' keyword produces a valid type)
	type : tyid;
	// category is lvalue or rvalue
	category : val_category;

	// if tag == val_tag.compile_time, this stores the value of the thing at compile-time (now)
	s : sval;
	// if tag == val_tag.runtime, this stores the psyir-level value representation of the thing
	ir : irval;
};

val_category : enum
{
	.lvalue := 0;
	.rvalue := 1;
};

val_tag : enum
{
	.compile_time := 0;
	.runtime := 1;
	.type_only := 2;
};

val_resolution : enum
{
	.type_only := 0;
	.compile_time_only := 1;
	.runtime_only := 2;
	.anything := 3;
};

sval_tag : enum
{
	.zero_value := 1;
	.undefined := 2;
	.literal := 3;
	.array_literal := 4;
	.struct_literal := 5;
};

// this gets messy really easily so i am going to be *very* specific
sval : struct
{
	// tells you what we're representing. do *not* assuem if val.type is an array type that our sval will always be sval_tag.array_literal. it could be zero, or undefined.
	tag : sval_tag;
	// if tag == sval_tag.literal, this has all the info you need. you can assume the literal-tag logically matches up with what the val.type is.
	literal : ast_literal;
	// if tag == sval_tag.array_literal or struct_literal, these represent the array elements (or struct members in-order) respectively. members_count should always be equal to countof(val.type), but they could all be undefined.
	members : sval mut?;
	// how many things have i stored for you in members
	members_count : u64;
	// internal.
	members_cap : u64;
};

val_from_node : func(node : ast mut?, s : scope mut?, r : val_resolution -> val)
{
	ret ::= val_from_node_inner(node, s, r);
	// todo: if we get something stricter than our resolution, convert it now (e.g compile_time -> runtime_only).
	return ret;
};
// given a node, get a value representation of it
// if type_only is true - the val will have a valid .type member but all other fields should be assumed to be undefined
val_from_node_inner : func(node : ast mut?, s : scope mut?, r : val_resolution -> val)
{
	if(ast_is_expr(node, ast_expr_tag.literal))
	{
		return val_from_literal(node->literal);
	}
	psyc_panic_begin(node);
	putzstr("reached end of val_from_node_inner");
	psyc_panic_end(node);
	return zero;
};

val_from_literal : func(literal : ast_literal -> val)
{
	ret ::= val mut
	{
		.tag := val_tag.compile_time;
		.category := val_category.rvalue;
		.s := sval{.tag := sval_tag.literal; .literal := literal;};
	};
	if(literal.tag == ast_literal_tag.integer)
	{
		ret.type = tyid_integral_literal();
	}
	if(literal.tag == ast_literal_tag.floating_point)
	{
		ret.type = tyid_floating_point_literal();
	}
	if(literal.tag == ast_literal_tag.char)
	{
		ret.type = tyid_char_literal();
	}
	if(literal.tag == ast_literal_tag.string)
	{
		ret.type = tyid_string_literal();
	}
	if(literal.tag == ast_literal_tag.boolean)
	{
		ret.type = tyid_bool_literal();
	}
	return ret;
};

val_from_integer_literal : func(int : s64 weak -> val)
{
	return val_from_literal(ast_literal{.tag := ast_literal_tag.integer; .integer := int;});
};

val_from_floating_point_literal : func(float : f64 weak -> val)
{
	return val_from_literal(ast_literal{.tag := ast_literal_tag.floating_point; .floating_point := float;});
};

val_from_char_literal : func(char : u8 weak -> val)
{
	return val_from_literal(ast_literal{.tag := ast_literal_tag.char; .char := char;});
};

val_from_string_literal : func(string : u8?, string_len : u64 -> val)
{
	return val_from_literal(ast_literal{.tag := ast_literal_tag.string; .string := string; .string_len := string_len;});
};

val_from_bool_literal : func(boolean : bool -> val)
{
	return val_from_literal(ast_literal{.tag := ast_literal_tag.boolean; .boolean := boolean;});
};

val_must_get_integer : func(v : val, source : ast mut? -> s64 weak)
{
	if(v.tag != val_tag.compile_time)
	{
		psyc_error_begin(source);
		putzstr("cannot statically retrieve literal.integer value from non-compile-time value");
		psyc_error_end(source);
	}
	if(v.s.tag == sval_tag.zero_value)
	{
		return 0;
	}
	if(v.s.tag == sval_tag.literal)
	{
		if(v.s.literal.tag == ast_literal_tag.integer)
		{
			return v.s.literal.integer;
		}
		psyc_error_begin(source);
		putzstr("cannot statically retrieve literal.integer value from literal.");
		putzstr(enumname(v.s.literal.tag));
		putzstr(" value");
		psyc_error_end(source);
	}
	psyc_error_begin(source);
	putzstr("cannot statically retrieve literal.integer value from non-literal ");
	putchar('"');
	putzstr(enumname(v.s.tag));
	putchar('"');
	putzstr(" value");
	psyc_error_end(source);
	return zero;
};

val_must_get_floating_point : func(v : val, source : ast mut? -> f64 weak)
{
	if(v.tag != val_tag.compile_time)
	{
		psyc_error_begin(source);
		putzstr("cannot statically retrieve literal.floating_point value from non-compile-time value");
		psyc_error_end(source);
	}
	if(v.s.tag == sval_tag.zero_value)
	{
		return 0.0;
	}
	if(v.s.tag == sval_tag.literal)
	{
		if(v.s.literal.tag == ast_literal_tag.floating_point)
		{
			return v.s.literal.floating_point;
		}
		psyc_error_begin(source);
		putzstr("cannot statically retrieve literal.floating_point value from literal.");
		putzstr(enumname(v.s.literal.tag));
		putzstr(" value");
		psyc_error_end(source);
	}
	psyc_error_begin(source);
	putzstr("cannot statically retrieve literal.floating_point value from non-literal ");
	putchar('"');
	putzstr(enumname(v.s.tag));
	putchar('"');
	putzstr(" value");
	psyc_error_end(source);
	return zero;
};

val_must_get_char : func(v : val, source : ast mut? -> u8)
{
	if(v.tag != val_tag.compile_time)
	{
		psyc_error_begin(source);
		putzstr("cannot statically retrieve literal.char value from non-compile-time value");
		psyc_error_end(source);
	}
	if(v.s.tag == sval_tag.zero_value)
	{
		return 0;
	}
	if(v.s.tag == sval_tag.literal)
	{
		if(v.s.literal.tag == ast_literal_tag.char)
		{
			return v.s.literal.char;
		}
		psyc_error_begin(source);
		putzstr("cannot statically retrieve literal.char value from literal.");
		putzstr(enumname(v.s.literal.tag));
		putzstr(" value");
		psyc_error_end(source);
	}
	psyc_error_begin(source);
	putzstr("cannot statically retrieve literal.char value from non-literal ");
	putchar('"');
	putzstr(enumname(v.s.tag));
	putchar('"');
	putzstr(" value");
	psyc_error_end(source);
	return zero;
};
