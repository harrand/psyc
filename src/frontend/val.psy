val_category : enum
{
	.lvalue := 0;
	.rvalue := 1;
};

val_type : enum
{
	.compile_time := 0;
	.runtime := 1;
};

val : struct
{
	type : tyid;
	category : val_category;
};

val_from_node : func(node : ast mut? -> val)
{
	return zero;
};

val_from_node_tbl ::= func(node : ast mut? -> val)[countof ast_tag]
{
	... := val_from_node_invalid;
};

val_from_node_invalid : func(node : ast mut? -> val)
{
	return zero;
};
