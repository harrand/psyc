ast_blkinit_get_inits : func(n : ast mut? -> ast mut?)
{
	return n->children # 1;
};

ast_dereference_get_operand : func(n : ast mut? -> ast mut?)
{
	return n->children # 0;
};

ast_cast_get_castee : func(n : ast mut? -> ast mut?)
{
	return n->children # 0;
};

ast_cast_get_cast_typename : func(n : ast mut? -> ast mut?)
{
	return n->children # 1;
};

ast_field_get_lhs : func(n : ast mut? -> ast mut?)
{
	return n->children # 0;
};

ast_field_get_rhs : func(n : ast mut? -> ast mut?)
{
	return n->children # 1;
};

ast_ptrfield_get_lhs : func(n : ast mut? -> ast mut?)
{
	return n->children # 0;
};

ast_ptrfield_get_rhs : func(n : ast mut? -> ast mut?)
{
	return n->children # 1;
};

ast_sizeof_get_operand : func(n : ast mut? -> ast mut?)
{
	return n->children # 0;
};

ast_alignof_get_operand : func(n : ast mut? -> ast mut?)
{
	return n->children # 0;
};

ast_countof_get_operand : func(n : ast mut? -> ast mut?)
{
	return n->children # 0;
};

// TOKEN -> AST CONVERSION

token2ast : func(in_tok : token mut?, out_ast : ast mut? -> v0)
{
	out_ast->tag = ast_tag.token;
	[ast_token_get_tag(out_ast)] = in_tok->tag;
	[ast_token_get_begin(out_ast)] = in_tok->begin;
	[ast_token_get_end(out_ast)] = in_tok->end;
	out_ast->children = zero;
	out_ast->children_count = 0;
	out_ast->children_cap = 0;
};

// DUMPING TO STDOUT

ast_dump_tbl ::= func(n : ast mut?, src : u8?, src_len : u64 -> v0)[countof ast_tag]
{
	.0 := ast_dump_root;
	.1 := ast_dump_token;
	.2 := ast_dump_expr;	
	.3 := ast_dump_stmt;
	.4 := ast_dump_decl;
	.5 := ast_dump_typename;
	.6 := ast_dump_init;
	.7 := ast_dump_structure;
	.8 := ast_dump_function;
	.9 := ast_dump_enumeration;
	.10 := ast_dump_assembly;
};

ast_dump_root : func(n : ast mut?, src : u8?, src_len : u64 -> v0)
{
	s ::= [ast_root_get_source(n)];
	srcptr ::= prog_get_source(s);
	if(srcptr == zero)
	{
		putzstr("root(unnamed)\n\0");
	}
	else
	{
		putzstr("root(\0");
		putzstr(path2zstr(srcptr->path));
		putzstr(")\n\0");
	}
};

ast_dump_token : func(n : ast mut?, src : u8?, src_len : u64 -> v0)
{
	putzstr("token \0");
	putuint([ast_token_get_tag(n)]@s64);
	putchar(' ');
	beg ::= [ast_token_get_begin(n)];
	end ::= [ast_token_get_end(n)];
	putchars(src # beg, end - beg);
	putzstr("\n\0");
};

ast_dump_expr : func(n : ast mut?, src : u8?, src_len : u64 -> v0)
{
	putzstr("expr\n\0");
};

ast_dump_stmt : func(n : ast mut?, src : u8?, src_len : u64 -> v0)
{
	putzstr("stmt\n\0");
};

ast_dump_decl : func(n : ast mut?, src : u8?, src_len : u64 -> v0)
{
	putzstr("decl\n\0");
};

ast_dump_typename : func(n : ast mut?, src : u8?, src_len : u64 -> v0)
{
	putzstr("typename\n\0");
};

ast_dump_init : func(n : ast mut?, src : u8?, src_len : u64 -> v0)
{
	putzstr("init\n\0");
};

ast_dump_structure : func(n : ast mut?, src : u8?, src_len : u64 -> v0)
{
	putzstr("structure\n\0");
};

ast_dump_function : func(n : ast mut?, src : u8?, src_len : u64 -> v0)
{
	putzstr("function\n\0");
};

ast_dump_enumeration : func(n : ast mut?, src : u8?, src_len : u64 -> v0)
{
	putzstr("enumeration\n\0");
};

ast_dump_assembly : func(n : ast mut?, src : u8?, src_len : u64 -> v0)
{
	putzstr("assembly\n\0");
};

ast_dump_one : func(n : ast mut?, src : u8?, src_len : u64, tabcount : u64 -> v0)
{
	i : u64 mut;
	for(i = 0; i < tabcount; i = i + 1)
	{
		putzstr("\t\0");
	}

	[ast_dump_tbl # (n->tag@s64)](n, src, src_len);
};

ast_dump_inner : func(n : ast mut?, src : u8?, src_len : u64, tabcount : u64 -> v0)
{
	ast_dump_one(n, src, src_len, tabcount);
	i : u64 mut;
	for(i = 0; i < n->children_count@u64; i = i + 1)
	{
		ast_dump_inner(n->children # i, src, src_len, tabcount + 1);
	}
};

ast_dump : func(n : ast mut?, src : u8?, src_len : u64 -> v0)
{
	ast_dump_inner(n, src, src_len, 0);
};
