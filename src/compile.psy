add_build_file : func(p : path -> v0)
{
	linux_write(1, "compiling ", 10);
	path_str ::= path2zstr(p);
	linux_write(1, path_str, zstrlen(path_str));
	linux_write(1, "...", 3);

	add_source_file(p);
};

add_source_file : func(p : path -> v0)
{
	stats : file_stats mut;
	path_get_stats(p, ref stats, file.none);
	ptr : u8 mut? := arena_alloc(global_arena, stats.size);
	f : file := path_open(p, file.cwd, file_access.read);
	debugbreak();
	file_read(f, ptr, stats.size);
};
