val_from_symbol : func(symbol_node : ast mut?, s : scope mut? -> val)
{
	symbol ::= symbol_node->symbol;
	// firstly check function name
	maybe_function ::= scope_find_function_with_fallback(s, symbol);
	if(maybe_function != zero)
	{
		return val_function_reference(maybe_function);
	}

	maybe_variable ::= scope_find_variable_with_fallback(s, symbol);
	if(maybe_variable != zero)
	{
		return val_variable_reference(maybe_variable, symbol_node);
	}

	maybe_assembly ::= scope_find_assembly_with_fallback(s, symbol);
	if(maybe_assembly != zero)
	{
		return val_assembly_reference(maybe_assembly);
	}

	maybe_type ::= ty_find_by_name(symbol);
	if(maybe_type != zero)
	{
		return val
		{
			.tag := val_tag.type_only;
			.type := maybe_type;
		};
	}

	// todo: impl
	psyc_panic_begin(symbol_node);
	putzstr("reached end of val_from_symbol");
	psyc_panic_end(symbol_node);
	return zero;
};

// verifies that the params passed to the callable are all kosher
// and returns an array containing the ready-to-go param vals
val_setup_call_params : func(callee : val, params_nodes : ast mut?, params_nodes_count : u64, s : scope mut?, r : val_resolution, source : ast mut? -> val mut?)
{
	callee_fnty ::= ty_unwrap(callee.type)->fn;

	if(params_nodes_count != callee_fnty.params_count)
	{
		psyc_error_begin(source);
		putzstr("incorrect number of arguments in call. expected ");
		putuint(callee_fnty.params_count);
		putzstr(", got ");
		putuint(params_nodes_count);
		psyc_error_end(source);
	}
	call_params : val mut? := arena_alloc(global_arena, params_nodes_count * sizeof val);
	i : u64 mut;
	for(i = 0; i < params_nodes_count; i = i + 1)
	{
		pnode ::= params_nodes # i;
		cur ::= val_must_convert(val_from_node(pnode, s, r), [callee_fnty.param_types # i], pnode);
		[call_params # i] = cur;
	}
	return call_params;
};


val_from_call : func(call_node : ast mut?, s : scope mut?, r : val_resolution -> val)
{
	i : u64 mut;
	// callee must be some type of callable
	callee ::= val_from_node(ast_get_child(call_node, 0), s, r);
	callee_fnty ::= ty_unwrap(callee.type)->fn;
	if(!ty_is_fn(callee.type))
	{
		psyc_error_begin(call_node);
		putzstr("attempt to call non-callable ");
		putchar('"');
		putty(callee.type);
		putchar('"');
		psyc_error_end(call_node);
	}

	// validate call params
	call_params_count ::= call_node->children_count - 1;
	call_params ::= val_setup_call_params(callee, ast_get_child(call_node, 1), call_params_count, s, r, call_node);

	if(callee.tag == val_tag.type_only)
	{
		return val_from_type(callee_fnty.return_type);
	}
	// todo: handle compile_time call
	// todo: handle runtime call
	if((r == val_resolution.runtime_only) || (r == val_resolution.either))
	{
		call_param_irvals : irval mut? := arena_alloc(global_arena, call_params_count * sizeof irval);
		// todo: handle more than just scalars...
		for(i = 0; i < call_params_count; i = i + 1)
		{
			param_node ::= ast_get_child(call_node, i + 1);
			runtime_param : val mut := val_ensure_runtime([call_params # i], param_node);
			if(runtime_param.category == val_category.lvalue)
			{
				runtime_param = codegen_load(runtime_param, param_node);
			}
			[call_param_irvals # i] = runtime_param.r.v;
		}
		ir_call(val_ensure_runtime(callee, ast_get_child(call_node, 0)).r.v, call_param_irvals # 0, call_params_count, zero, zero, zero);
		return zero;
	}
	psyc_panic_begin(call_node);
	putzstr("reached end of val_from_call");
	psyc_panic_end(call_node);
	return zero;
};

val_from_cast : func(cast_node : ast mut?, s : scope mut?, r : val_resolution -> val)
{
	castee_node ::= ast_get_child(cast_node, 0);
	castee ::= val_from_node(castee_node, s, r);
	cast_to_node ::= ast_get_child(cast_node, 1);
	cast_to ::= type_from_typename_node(cast_to_node, s);

	return val_must_convert(castee, cast_to, cast_node);
};

val_from_biop : func(biop_node : ast mut?, s : scope mut?, r : val_resolution -> val)
{
	lhs_node ::= ast_get_child(biop_node, 0);
	rhs_node ::= ast_get_child(biop_node, 1);

	lhs : val mut := val_from_node(lhs_node, s, r);
	rhs : val mut := val_from_node(rhs_node, s, r);

	ret_type : tyid mut := zero;
	if(ast_biop_is_compare(biop_node))
	{
		ret_type = tyid.bool;
	}
	else
	{
		if(biop_node->biop.op == ast_biop_op.assign)
		{
			ret_type = lhs.type;
			if(!ty_has_qual(lhs.type, tyqual.qual_mut))
			{
				psyc_error_begin(biop_node);
				putzstr("invalid assign to non-mutable left-hand-side operand of type ");
				putchar('"');
				putty(lhs.type);
				putchar('"');
				psyc_error_end(biop_node);
			}
			if(lhs.category != val_category.lvalue)
			{
				psyc_error_begin(biop_node);
				putzstr("invalid assign to rvalue");
				psyc_error_end(biop_node);
			}
			rhs = val_must_convert(rhs, lhs.type, biop_node);
		}
		else
		{
			if(biop_node->biop.op == ast_biop_op.at)
			{
				ret_type = ty_ptr(ty_underlying(lhs.type), zero);
			}
			else
			{
				ret_type = ty_of_arithmetic(lhs.type, rhs.type);
			}
		}
	}

	// if we are not assign, then both must be loaded if needed
	// if we are assign, only rhs needs to be loaded
	if((lhs.category == val_category.lvalue) && (biop_node->biop.op != ast_biop_op.assign))
	{
		lhs = codegen_load(lhs, biop_node);
	}
	if(rhs.category == val_category.lvalue)
	{
		rhs = codegen_load(rhs, biop_node);
	}

	if(ret_type == zero)
	{
		psyc_error_begin(biop_node);
		putzstr("binary operator ");
		putchar('"');
		putzstr(enumname(biop_node->biop.op));
		putchar('"');
		putzstr(" is invalid on types ");
		putchar('"');
		putty(lhs.type);
		putchar('"');
		putzstr(" and ");
		putchar('"');
		putty(lhs.type);
		putchar('"');
		psyc_error_end(biop_node);
	}
	if(r == val_resolution.type_only)
	{
		return val_from_type(ret_type);
	}

	// get a common resolution of lhs, rhs and the parameter
	// lowest one of them all is used
	lowest_common_resolution : val_resolution mut := val_resolution.either;
	if((lhs.tag == val_tag.runtime) || (rhs.tag == val_tag.runtime))
	{
		// must be runtime
		lowest_common_resolution = val_resolution.runtime_only;
		if(r == val_resolution.compile_time_only)
		{
			// error: we were asked for a compile-time value but one of the operands is runtime only
			psyc_error_begin(biop_node);
			putzstr("binary operator must be evaluated at compile-time, but this is impossible because ");
			if((lhs.tag == val_tag.runtime) && (rhs.tag == val_tag.runtime))
			{
				putzstr("both operands are runtime-values");
			}
			else
			{
				if(lhs.tag == val_tag.runtime)
				{
					putzstr("the left-hand-side operand is a runtime-value");
				}
				else
				{
					putzstr("the right-hand-side operand is a runtime-value");
				}
			}
			psyc_error_end(biop_node);
		}
	}
	else
	{
		lowest_common_resolution = r;
	}

	ret_category : val_category mut := val_category.rvalue;
	if(biop_node->biop.op == ast_biop_op.at)
	{
		ret_category = val_category.lvalue;
	}

	if(lowest_common_resolution == val_resolution.runtime_only)
	{
		return val
		{
			.tag := val_tag.runtime;
			.type := ret_type;
			.category := ret_category;
			.r := rval_from_biop(biop_node->biop.op, val_ensure_runtime(lhs, biop_node), val_ensure_runtime(rhs, biop_node), s, biop_node);
		};
	}
	else
	{
		return val
		{
			.tag := val_tag.compile_time;
			.type := ret_type;
			.category := ret_category;
			.s := sval_from_biop(biop_node->biop.op, val_must_be_compile_time(lhs, biop_node), val_must_be_compile_time(rhs, biop_node), s, biop_node);
		};
	}
	psyc_panic_begin(biop_node);
	putzstr("reached end of val_from_biop");
	psyc_panic_end(biop_node);
	return zero;
};

val_function_reference : func(fn : function mut? -> val)
{
	return val
	{
		.tag := val_tag.compile_time;
		.type := fn->type;
		.category := val_category.rvalue;
		.s := sval
		{
			.tag := sval_tag.function_reference;
			.ptr := fn;
		};
	};
};

val_variable_reference : func(var : variable mut?, source : ast mut? -> val)
{
	// the variable reference is easy.
	// but if the variable is of runtime type, then there really is no good pretending we have a compile-time value so we immediately runtime-ify it
	// note: if we're doing build region stuff then in theory we might always want the variable reference even if the type is not static... in which case i suggest making a second function that always gets a variable reference, or provide a resolution parameter to this function? not sure.
	varref ::= val
	{
		.tag := val_tag.compile_time;
		.type := var->type;
		.category := val_category.lvalue;
		.s := sval
		{
			.tag := sval_tag.variable_reference;
			.ptr := var;
		};
	};
	if(ty_has_qual(var->type, tyqual.qual_static))
	{
		return varref;
	}
	return val_ensure_runtime(varref, source);
};

val_assembly_reference : func(as : assembly mut? -> val)
{
	return val
	{
		.tag := val_tag.compile_time;
		.type := as->type;
		.category := val_category.rvalue;
		.s := sval
		{
			.tag := sval_tag.assembly_reference;
			.ptr := as;
		};
	};
};

val_must_convert : func(from : val mut, to : tyid, source : ast mut? -> val)
{
	conv ::= ty_converts_to(from.type, to);

	if((conv != tyconv.yes) && (conv != tyconv.yes_needs_convert))
	{
		psyc_error_begin(source);
		putzstr("no valid conversion from ");
		putty(from.type);
		putzstr(" to ");
		if(conv == tyconv.no_cant_add_staticness)
		{
			putzstr(" (cannot add staticness)");
		}
		if(conv == tyconv.no_but_yes_with_weak)
		{
			putzstr(" (but an explicit conversion would work)");
		}
		psyc_error_end(source);
	}

	if(from.tag == val_tag.type_only)
	{
		return val_from_type(to);
	}
	if((from.tag == val_tag.compile_time) && (from.s.tag == sval_tag.variable_reference))
	{
		// if the variable is static then we can get its init node now i guess and go into sval_must_convert
		// but if its not, then we fallback to runtime.
		if(ty_has_qual(from.type, tyqual.qual_static))
		{
			// todo: get static value (probably have to get init node again because we dont currently store that in variable mut? (maybe we should?))
			psyc_panic_begin(source);
			putzstr("todo: given static variable_reference, get its static value initialiser");
			psyc_panic_end(source);
		}
		else
		{
			from = val_ensure_runtime(from, source);
		}
	}

	ret_category : val_category mut := from.category;
	// if no conversion was necessary, then preserve value category of the source
	// if a conversion is necessary, it must be an rvalue
	if(conv == tyconv.yes_needs_convert)
	{
		ret_category = val_category.rvalue;
	}
	if(from.tag == val_tag.compile_time)
	{
		return val
		{
			.tag := val_tag.compile_time;
			.type := to;
			.category := ret_category;
			.s := sval_must_convert(from, to, source);
		};
	}
	if(from.tag == val_tag.runtime)
	{
		return val
		{
			.tag := val_tag.runtime;
			.type := to;
			.category := ret_category;
			.r := rval_must_convert(from, to, source);
		};
	}

	// todo: impl
	psyc_panic_begin(source);
	putzstr("reached end of val_must_convert");
	psyc_panic_end(source);
	return zero;
};

sval_must_convert : func(from : val mut, to : tyid, source : ast mut? -> sval)
{
	if(ty_matches_ignore_quals(from.type, to))
	{
		return from.s;
	}
	// 'zero' and 'undefined' transcend types
	if((from.s.tag == sval_tag.zero_value) || (from.s.tag == sval_tag.undefined))
	{
		return from.s;
	}
	if(from.s.tag == sval_tag.literal)
	{
		from_sz ::= ty_floating_point_size(from.type) + ty_integral_size(from.type);
		to_sz ::= ty_floating_point_size(to) + ty_integral_size(to);
		// int to int
		if(ty_is_integral(from.type) && ty_is_integral(to))
		{
			if(to_sz == 8)
			{
				from.s.literal.integer = (from.s.literal.integer@s8)@_;
			}
			if(to_sz == 16)
			{
				from.s.literal.integer = (from.s.literal.integer@s16)@_;
			}
			if(to_sz == 32)
			{
				from.s.literal.integer = (from.s.literal.integer@s32)@_;
			}
			if(to_sz == 64)
			{
				from.s.literal.integer = (from.s.literal.integer@s32)@_;
			}
			return from.s;
		}
		// float to float
		if(ty_is_floating_point(from.type) && ty_is_floating_point(to))
		{
			if(to_sz == 32)
			{
				from.s.literal.floating_point = (from.s.literal.floating_point@f32)@_;
			}
			if(to_sz == 64)
			{
				from.s.literal.floating_point = (from.s.literal.floating_point@f64)@_;
			}
			return from.s;
		}
		// int to float
		if(ty_is_integral(from.type) && ty_is_floating_point(to))
		{
			if(to_sz == 32)
			{
				from.s.literal.floating_point = (from.s.literal.integer)@f32@_;
			}
			if(to_sz == 64)
			{
				from.s.literal.floating_point = (from.s.literal.integer)@f64@_;
			}
			from.s.literal.tag = ast_literal_tag.floating_point;
			return from.s;
		}
		// float to int
		if(ty_is_floating_point(from.type) && ty_is_integral(to))
		{
			if(to_sz == 8)
			{
				from.s.literal.integer = (from.s.literal.floating_point@s8)@_;
			}
			if(to_sz == 16)
			{
				from.s.literal.integer = (from.s.literal.floating_point@s16)@_;
			}
			if(to_sz == 32)
			{
				from.s.literal.integer = (from.s.literal.floating_point@s32)@_;
			}
			if(to_sz == 64)
			{
				from.s.literal.integer = (from.s.literal.floating_point@s32)@_;
			}
			from.s.literal.tag = ast_literal_tag.integer;
			return from.s;
		}
		// bool to int
		if(ty_is_bool(from.type) && ty_is_integral(to))
		{
			from.s.literal.tag = ast_literal_tag.integer;
			from.s.literal.integer = (from.s.literal.boolean == true)@_;
			return from.s;
		}
		// int to bool
		if(ty_is_integral(from.type) && ty_is_bool(to))
		{
			from.s.literal.tag = ast_literal_tag.boolean;
			from.s.literal.boolean = (from.s.literal.integer != 0);
			return from.s;
		}
	}
	psyc_panic_begin(source);
	putzstr("reached end of sval_must_convert");
	psyc_panic_end(source);
	return zero;
};

rval_must_convert : func(from : val mut, to : tyid, source : ast mut? -> rval)
{
	if(ty_matches_ignore_quals(from.type, to))
	{
		return from.r;
	}
	if(from.category == val_category.lvalue)
	{
		// must load
		from = codegen_load(from, source);
	}
	if(ty_is_prim(from.type) && ty_is_prim(to))
	{
		outsz : irsz mut;
		from_sz ::= ty_floating_point_size(from.type) + ty_integral_size(from.type);
		to_sz ::= ty_floating_point_size(to) + ty_integral_size(to);
		// int to int
		if(ty_is_integral(from.type) && ty_is_integral(to))
		{
			if(to_sz == from_sz)
			{
				return from.r;
			}
			if(from_sz == 8)
			{
				outsz = irsz.b;
			}
			if(from_sz == 16)
			{
				outsz = irsz.w;
			}
			if(from_sz == 32)
			{
				outsz = irsz.d;
			}
			if(from_sz == 64)
			{
				outsz = irsz.q;
			}
			if(to_sz < from_sz)
			{
				// increase size...
				if(ty_is_signed_integral(from.type))
				{
					// signed => sex
					from.r.v = ir_sex(outsz, from.r.v);
				}
				else
				{
					// unsigned => zex
					from.r.v = ir_zex(outsz, from.r.v);
				}
			}
			else
			{
				// decrease size => trunc
				from.r.v = ir_trunc(outsz, from.r.v);
			}
			return from.r;
		}
		// float to float
		if(ty_is_floating_point(from.type) && ty_is_floating_point(to))
		{
			psyc_panic_begin(source);
			putzstr("float-to-float conversions are not yet supported by the IR");
			psyc_panic_end(source);
			return zero;
		}
		// int to float
		if(ty_is_integral(from.type) && ty_is_floating_point(to))
		{
			if(to_sz == 32)
			{
				outsz = irsz.f;
			}
			if(to_sz == 64)
			{
				outsz = irsz.ff;
			}
			from.r.v = ir_cvtf(outsz, from.r.v);
			return from.r;
		}
		// float to int
		if(ty_is_floating_point(from.type) && ty_is_integral(to))
		{
			if(to_sz == 8)
			{
				outsz = irsz.b;
			}
			if(to_sz == 16)
			{
				outsz = irsz.w;
			}
			if(to_sz == 32)
			{
				outsz = irsz.d;
			}
			if(to_sz == 64)
			{
				outsz = irsz.q;
			}
			// todo: use signed/unsigned variants of cvti in the IR because currently ther e is only one which is wrong
			from.r.v = ir_cvti(outsz, from.r.v);
			return from.r;
		}
		if(ty_is_bool(from.type) && ty_is_integral(to))
		{
			// same as u8
			if(to_sz == 8)
			{
				return from.r;
			}
			if(to_sz == 16)
			{
				outsz = irsz.w;
			}
			if(to_sz == 32)
			{
				outsz = irsz.d;
			}
			if(to_sz == 64)
			{
				outsz = irsz.q;
			}
			from.r.v = ir_zex(outsz, from.r.v);
			return from.r;
		}
		if(ty_is_integral(from.type) && ty_is_bool(to))
		{
			if(from_sz == 8)
			{
				return from.r;
			}
			from.r.v = ir_trunc(irsz.b, from.r.v);
			return from.r;
		}
	}
	// todo: impl
	psyc_panic_begin(source);
	putzstr("reached end of rval_must_convert");
	psyc_panic_end(source);
	return zero;
};

sval_from_biop : func(op : ast_biop_op, lhs : val, rhs : val, s : scope mut?, source : ast mut? -> sval)
{
	if(op == ast_biop_op.add)
	{
		return sval_from_biop_add(lhs, rhs, s, source);
	}
	if(op == ast_biop_op.sub)
	{
		return sval_from_biop_sub(lhs, rhs, s, source);
	}
	if(op == ast_biop_op.mul)
	{
		return sval_from_biop_mul(lhs, rhs, s, source);
	}
	if(op == ast_biop_op.div)
	{
		return sval_from_biop_div(lhs, rhs, s, source);
	}
	psyc_panic_begin(source);
	putzstr("reached end of sval_from_biop (");
	putzstr(enumname(op));
	putzstr(")");
	psyc_panic_end(source);
	return zero;
};

sval_from_biop_add : func(lhs : val, rhs : val, s : scope mut?, source : ast mut? -> sval)
{
	// always assume these are scalars
	return sval
	{
		.tag := sval_tag.literal;
		.literal := ast_literal
		{
			.tag := ast_literal_tag.integer;
			.integer := lhs.s.literal.integer + rhs.s.literal.integer;
		};
	};
};

sval_from_biop_sub : func(lhs : val, rhs : val, s : scope mut?, source : ast mut? -> sval)
{
	// always assume these are scalars
	return sval
	{
		.tag := sval_tag.literal;
		.literal := ast_literal
		{
			.tag := ast_literal_tag.integer;
			.integer := lhs.s.literal.integer - rhs.s.literal.integer;
		};
	};
};

sval_from_biop_mul : func(lhs : val, rhs : val, s : scope mut?, source : ast mut? -> sval)
{
	// always assume these are scalars
	return sval
	{
		.tag := sval_tag.literal;
		.literal := ast_literal
		{
			.tag := ast_literal_tag.integer;
			.integer := lhs.s.literal.integer * rhs.s.literal.integer;
		};
	};
};

sval_from_biop_div : func(lhs : val, rhs : val, s : scope mut?, source : ast mut? -> sval)
{
	// always assume these are scalars
	return sval
	{
		.tag := sval_tag.literal;
		.literal := ast_literal
		{
			.tag := ast_literal_tag.integer;
			.integer := lhs.s.literal.integer / rhs.s.literal.integer;
		};
	};
};

rval_from_biop : func(op : ast_biop_op, lhs : val, rhs : val, s : scope mut?, source : ast mut? -> rval)
{
	if(op == ast_biop_op.assign)
	{
		return rval_from_biop_assign(lhs, rhs, s, source);
	}
	if(op == ast_biop_op.add)
	{
		return rval_from_biop_add(lhs, rhs, s, source);
	}
	if(op == ast_biop_op.sub)
	{
		return rval_from_biop_sub(lhs, rhs, s, source);
	}
	if(op == ast_biop_op.mul)
	{
		return rval_from_biop_mul(lhs, rhs, s, source);
	}
	if(op == ast_biop_op.div)
	{
		return rval_from_biop_div(lhs, rhs, s, source);
	}
	if(op == ast_biop_op.compare_equal)
	{
		return rval_from_biop_compare_equal(lhs, rhs, s, source);
	}
	if(op == ast_biop_op.compare_not_equal)
	{
		return rval_from_biop_compare_equal(lhs, rhs, s, source);
	}
	if(op == ast_biop_op.compare_less)
	{
		return rval_from_biop_compare_less(lhs, rhs, s, source);
	}
	if(op == ast_biop_op.compare_less_equal)
	{
		return rval_from_biop_compare_less_equal(lhs, rhs, s, source);
	}
	if(op == ast_biop_op.compare_greater)
	{
		return rval_from_biop_compare_greater(lhs, rhs, s, source);
	}
	if(op == ast_biop_op.compare_greater_equal)
	{
		return rval_from_biop_compare_greater_equal(lhs, rhs, s, source);
	}
	psyc_panic_begin(source);
	putzstr("reached end of rval_from_biop (");
	putzstr(enumname(op));
	putzstr(")");
	psyc_panic_end(source);
	return zero;
};

rval_from_biop_assign : func(lhs : val, rhs : val, s : scope mut?, source : ast mut? -> rval)
{
	codegen_store(lhs, rhs, source);
	return lhs.r;
};

rval_from_biop_add : func(lhs : val, rhs : val, s : scope mut?, source : ast mut? -> rval)
{
	// always assume these are scalars
	return rval
	{
		.tag := rval_tag.scalar;
		.v := ir_add(lhs.r.v, rhs.r.v);
	};
};

rval_from_biop_sub : func(lhs : val, rhs : val, s : scope mut?, source : ast mut? -> rval)
{
	// always assume these are scalars
	return rval
	{
		.tag := rval_tag.scalar;
		.v := ir_sub(lhs.r.v, rhs.r.v);
	};
};

rval_from_biop_mul : func(lhs : val, rhs : val, s : scope mut?, source : ast mut? -> rval)
{
	// always assume these are scalars
	type ::= ty_of_arithmetic(lhs.type, rhs.type);
	if(ty_is_signed_integral(type))
	{
		return rval
		{
			.tag := rval_tag.scalar;
			.v := ir_smul(lhs.r.v, rhs.r.v);
		};
	}
	return rval
	{
		.tag := rval_tag.scalar;
		.v := ir_umul(lhs.r.v, rhs.r.v);
	};
};

rval_from_biop_div : func(lhs : val, rhs : val, s : scope mut?, source : ast mut? -> rval)
{
	// always assume these are scalars
	type ::= ty_of_arithmetic(lhs.type, rhs.type);
	if(ty_is_signed_integral(type))
	{
		return rval
		{
			.tag := rval_tag.scalar;
			.v := ir_sdiv(lhs.r.v, rhs.r.v);
		};
	}
	return rval
	{
		.tag := rval_tag.scalar;
		.v := ir_udiv(lhs.r.v, rhs.r.v);
	};
};

rval_from_biop_compare_equal : func(lhs : val, rhs : val, s : scope mut?, source : ast mut? -> rval)
{
	return rval
	{
		.tag := rval_tag.scalar;
		.v := ir_cmp_eq(lhs.r.v, rhs.r.v);
	};
};

rval_from_biop_compare_not_equal : func(lhs : val, rhs : val, s : scope mut?, source : ast mut? -> rval)
{
	return rval
	{
		.tag := rval_tag.scalar;
		.v := ir_cmp_eq(lhs.r.v, rhs.r.v);
	};
};

rval_from_biop_compare_less : func(lhs : val, rhs : val, s : scope mut?, source : ast mut? -> rval)
{
	type ::= ty_of_arithmetic(lhs.type, rhs.type);
	if(ty_is_signed_integral(type))
	{
		return rval
		{
			.tag := rval_tag.scalar;
			.v := ir_cmp_slt(lhs.r.v, rhs.r.v);
		};
	}

	return rval
	{
		.tag := rval_tag.scalar;
		.v := ir_cmp_ult(lhs.r.v, rhs.r.v);
	};
};

rval_from_biop_compare_less_equal : func(lhs : val, rhs : val, s : scope mut?, source : ast mut? -> rval)
{
	type ::= ty_of_arithmetic(lhs.type, rhs.type);
	if(ty_is_signed_integral(type))
	{
		return rval
		{
			.tag := rval_tag.scalar;
			.v := ir_cmp_sle(lhs.r.v, rhs.r.v);
		};
	}

	return rval
	{
		.tag := rval_tag.scalar;
		.v := ir_cmp_ule(lhs.r.v, rhs.r.v);
	};
};

rval_from_biop_compare_greater : func(lhs : val, rhs : val, s : scope mut?, source : ast mut? -> rval)
{
	type ::= ty_of_arithmetic(lhs.type, rhs.type);
	if(ty_is_signed_integral(type))
	{
		return rval
		{
			.tag := rval_tag.scalar;
			.v := ir_cmp_sgt(lhs.r.v, rhs.r.v);
		};
	}

	return rval
	{
		.tag := rval_tag.scalar;
		.v := ir_cmp_ugt(lhs.r.v, rhs.r.v);
	};
};

rval_from_biop_compare_greater_equal : func(lhs : val, rhs : val, s : scope mut?, source : ast mut? -> rval)
{
	type ::= ty_of_arithmetic(lhs.type, rhs.type);
	if(ty_is_signed_integral(type))
	{
		return rval
		{
			.tag := rval_tag.scalar;
			.v := ir_cmp_sge(lhs.r.v, rhs.r.v);
		};
	}

	return rval
	{
		.tag := rval_tag.scalar;
		.v := ir_cmp_uge(lhs.r.v, rhs.r.v);
	};
};

val_from_type : func(type : tyid -> val)
{
	return val
	{
		.tag := val_tag.type_only;
		.type := type;
	};
};

// given a val, if its an rval, error out. if its a sval, do nothing
val_must_be_compile_time : func(v : val, source : ast mut? -> val)
{
	if(v.tag == val_tag.runtime)
	{
		psyc_error_begin(source);
		putzstr("value must be statically known in this context, but can only produce a value at runtime");
		psyc_error_end(source);
	}
	return v;
};

// given a val, if its an rval, do nothing. if its a sval, convert it to an rval
val_ensure_runtime : func(v : val, source : ast mut? -> val)
{
	if(v.tag == val_tag.runtime)
	{
		return v;
	}
	if(v.tag == val_tag.type_only)
	{
		psyc_panic_begin(source);
		putzstr("call to val_ensure_runtime on a typeonly val representing the type ");
		putchar('"');
		putty(v.type);
		putchar('"');
		psyc_panic_end(source);
	}
	if(v.s.tag == sval_tag.literal)
	{
		if(v.s.literal.tag == ast_literal_tag.integer)
		{
			// integer literal -> runtime value
			return val
			{
				.tag := val_tag.runtime;
				.type := v.type;
				.category := val_category.rvalue;
				.r := rval
				{
					.tag := rval_tag.scalar;
					.v := irval_qimm(v.s.literal.integer);
				};
			};
		}
		if(v.s.literal.tag == ast_literal_tag.floating_point)
		{
			// floating-point literal -> runtime value
			return val
			{
				.tag := val_tag.runtime;
				.type := v.type;
				.category := val_category.rvalue;
				.r := rval
				{
					.tag := rval_tag.scalar;
					.v := irval_ffimm(v.s.literal.floating_point);
				};
			};
		}
		if(v.s.literal.tag == ast_literal_tag.char)
		{
			// floating-point literal -> runtime value
			return val
			{
				.tag := val_tag.runtime;
				.type := v.type;
				.category := val_category.rvalue;
				.r := rval
				{
					.tag := rval_tag.scalar;
					.v := irval_bimm(v.s.literal.char);
				};
			};
		}
		if(v.s.literal.tag == ast_literal_tag.string)
		{
			// string literal -> runtime value
			return val
			{
				.tag := val_tag.runtime;
				.type := v.type;
				.category := val_category.rvalue;
				.r := rval
				{
					.tag := rval_tag.scalar;
					.v := ir_add_glob(v.s.literal.string, v.s.literal.string_len, false);
				};
			};
		}
		if(v.s.literal.tag == ast_literal_tag.boolean)
		{
			// floating-point literal -> runtime value
			return val
			{
				.tag := val_tag.runtime;
				.type := v.type;
				.category := val_category.rvalue;
				.r := rval
				{
					.tag := rval_tag.scalar;
					.v := irval_bimm(v.s.literal.boolean);
				};
			};
		}
	}
	if(v.s.tag == sval_tag.function_reference)
	{
		fn ::= v.s.ptr@function mut?;
		return val
		{
			.tag := val_tag.runtime;
			.type := v.type;
			.category := val_category.rvalue;
			.r := rval
			{
				.tag := rval_tag.scalar;
				.v := irval_funcref(fn->fnref);
			};
		};
	}
	if(v.s.tag == sval_tag.variable_reference)
	{
		// a variable reference that is a parameter is not an lvalue, but if its a local variable or global then it is an lvalue
		var ::= v.s.ptr@variable mut?;
		var_category : val_category mut := val_category.lvalue;
		if(var->local_param_idx != ~0)
		{
			var_category = val_category.rvalue;
		}
		return val
		{
			.tag := val_tag.runtime;
			.type := v.type;
			.category := var_category;
			.r := var->runtime_storage;
		};
	}
	if(v.s.tag == sval_tag.assembly_reference)
	{
		as ::= v.s.ptr@assembly mut?;
		return val
		{
			.tag := val_tag.runtime;
			.type := v.type;
			.category := val_category.rvalue;
			.r := rval
			{
				.tag := rval_tag.scalar;
				.v := irval_asmref(as->asm_ir_idx);
			};
		};
	}
	psyc_panic_begin(source);
	putzstr("reached end of val_ensure_runtime");
	psyc_panic_end(source);
	return zero;
};
