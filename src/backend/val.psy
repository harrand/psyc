rval_from_biop_at : func(lhs : val mut, rhs : val, s : scope mut?, source : ast mut? -> rval)
{
	// lhs is some kind of pointer
	if(ty_is_ptr(lhs.type))
	{
		lhs = codegen_load_if_lvalue(lhs, source);
	}
	// ok we're either an rval.ptr or an rval.scalar that represents a pointer.
	// doesnt matter - we just add anyway
	elem_size ::= datalayout_sizeof_ty(ty_underlying(lhs.type));
	// todo: ideally we dont add/mul here we turn it into an rval suitable for a memory operand with all this data encoded. toughie though.
	// todo: if rhs.r.v is an immediate 0 value, we dont need the add or the mul
	lhs.r.v = ir_add(lhs.r.v, ir_umul(rhs.r.v, irval_imm(irval_get_irsz(rhs.r.v), elem_size)));
	return lhs.r;
};

val_from_type : func(type : tyid -> val)
{
	return val
	{
		.tag := val_tag.type_only;
		.type := type;
	};
};

// given a val, if its an rval, error out. if its a sval, do nothing
val_must_be_compile_time : func(v : val, source : ast mut? -> val)
{
	if(v.tag == val_tag.runtime)
	{
		psyc_error_begin(source);
		putzstr("value must be statically known in this context, but can only produce a value at runtime");
		psyc_error_end(source);
	}
	return v;
};

// given a val, if its an rval, do nothing. if its a sval, convert it to an rval
val_ensure_runtime : func(v : val, source : ast mut? -> val)
{
	if(v.tag == val_tag.runtime)
	{
		return v;
	}
	if(v.tag == val_tag.type_only)
	{
		psyc_panic_begin(source);
		putzstr("call to val_ensure_runtime on a typeonly val representing the type ");
		putchar('"');
		putty(v.type);
		putchar('"');
		psyc_panic_end(source);
	}
	if(v.s.tag == sval_tag.literal)
	{
		if(v.s.literal.tag == ast_literal_tag.integer)
		{
			// integer literal -> runtime value
			return val
			{
				.tag := val_tag.runtime;
				.type := v.type;
				.category := val_category.rvalue;
				.r := rval
				{
					.tag := rval_tag.scalar;
					.v := irval_qimm(v.s.literal.integer);
				};
			};
		}
		if(v.s.literal.tag == ast_literal_tag.floating_point)
		{
			// floating-point literal -> runtime value
			return val
			{
				.tag := val_tag.runtime;
				.type := v.type;
				.category := val_category.rvalue;
				.r := rval
				{
					.tag := rval_tag.scalar;
					.v := irval_ffimm(v.s.literal.floating_point);
				};
			};
		}
		if(v.s.literal.tag == ast_literal_tag.char)
		{
			// floating-point literal -> runtime value
			return val
			{
				.tag := val_tag.runtime;
				.type := v.type;
				.category := val_category.rvalue;
				.r := rval
				{
					.tag := rval_tag.scalar;
					.v := irval_bimm(v.s.literal.char);
				};
			};
		}
		if(v.s.literal.tag == ast_literal_tag.string)
		{
			// string literal -> runtime value
			return val
			{
				.tag := val_tag.runtime;
				.type := v.type;
				.category := val_category.rvalue;
				.r := rval
				{
					.tag := rval_tag.scalar;
					.v := ir_add_glob(v.s.literal.string, v.s.literal.string_len, false);
				};
			};
		}
		if(v.s.literal.tag == ast_literal_tag.boolean)
		{
			// floating-point literal -> runtime value
			return val
			{
				.tag := val_tag.runtime;
				.type := v.type;
				.category := val_category.rvalue;
				.r := rval
				{
					.tag := rval_tag.scalar;
					.v := irval_bimm(v.s.literal.boolean);
				};
			};
		}
	}
	if(v.s.tag == sval_tag.function_reference)
	{
		fn ::= v.s.ptr@function mut?;
		return val
		{
			.tag := val_tag.runtime;
			.type := v.type;
			.category := val_category.rvalue;
			.r := rval
			{
				.tag := rval_tag.scalar;
				.v := irval_funcref(fn->fnref);
			};
		};
	}
	if(v.s.tag == sval_tag.variable_reference)
	{
		// a variable reference that is a parameter is not an lvalue, but if its a local variable or global then it is an lvalue
		var ::= v.s.ptr@variable mut?;
		var_category : val_category mut := val_category.lvalue;
		if(var->local_param_idx != ~0)
		{
			var_category = val_category.rvalue;
		}
		return val
		{
			.tag := val_tag.runtime;
			.type := v.type;
			.category := var_category;
			.r := var->runtime_storage;
		};
	}
	if(v.s.tag == sval_tag.assembly_reference)
	{
		as ::= v.s.ptr@assembly mut?;
		return val
		{
			.tag := val_tag.runtime;
			.type := v.type;
			.category := val_category.rvalue;
			.r := rval
			{
				.tag := rval_tag.scalar;
				.v := irval_asmref(as->asm_ir_idx);
			};
		};
	}
	if(v.s.tag == sval_tag.struct_literal)
	{
		// runtime them all.
		strct ::= ty_unwrap(v.type)->strct;
		i : u64 mut;
		chunks : chunk mut[128] := zero;
		chunks_count ::= chunk_tys(chunking_rules_psy, ref(v.type), 1, chunks # 0);

		members : rval mut? := arena_alloc(global_arena, chunks_count * sizeof rval);
		members_chunks : chunk mut? := arena_alloc(global_arena, chunks_count * sizeof chunk);
		memcopy(members_chunks, chunks # 0, chunks_count * sizeof chunk);
	
		wv ::= bwriter mut
		{
			.endian := native_endianness();
			.buf := zero;
			.len := zero;
			.cursor := zero;
			.ar := global_arena;
		};
		w ::= ref wv;
		// we've serialised it out now
		datalayout_serialise_compile_time_val(ref wv, v);
		// go through the chunks, gather offsets from 0, and just copy it over...
		cursor : u64 mut := 0;
		for(i = 0; i < chunks_count; i = i + 1)
		{
			chnk ::= chunks # i;
			sz ::= chunk_to_irsz(chnk);
			scratch : u64 mut := zero;
			memcopy(ref scratch, wv.buf # cursor, chnk->sz);
			[members # i] = rval
			{
				.tag := rval_tag.scalar;
				.v := irval_imm(sz, scratch);
			};

			cursor = cursor + chnk->sz;
		}
		return val
		{
			.tag := val_tag.runtime;
			.type := v.type;
			.category := val_category.rvalue;
			.r := rval
			{
				.tag := rval_tag.chunked;
				.members := members;
				.members_chunks := members_chunks;
				.members_count := chunks_count;
			};
		};
	}
	psyc_panic_begin(source);
	putzstr("reached end of val_ensure_runtime");
	psyc_panic_end(source);
	return zero;
};

rval_fully_unpack : func(r : rval, out_vals : irval mut? mut?, out_vals_count : u64 mut? -> v0)
{
	if(r.tag != rval_tag.chunked)
	{
		[out_vals] = arena_alloc(global_arena, sizeof irval);
		[[out_vals] # 0] = r.v;
		[out_vals_count] = 1;
		return;
	}
	out_vals_cap : u64 mut := r.members_count;
	[out_vals] = arena_alloc(global_arena, out_vals_cap * sizeof irval);
	[out_vals_count] = 0;

	i : u64 mut;
	j : u64 mut;
	total_count : u64 mut := 0;
	for(i = 0; i < r.members_count; i = i + 1)
	{
		mem ::= [r.members # i];
		inner_vals : irval mut? mut;
		inner_vals_count : u64 mut;
		rval_fully_unpack(mem, ref inner_vals, ref inner_vals_count);
		for(j = 0; j < inner_vals_count; j = j + 1)
		{
			while([out_vals_count] >= out_vals_cap)
			{
				olddata ::= [out_vals];
				oldcap ::= out_vals_cap;
				out_vals_cap = out_vals_cap * 2;
				[out_vals] = arena_alloc(global_arena, out_vals_cap * sizeof irval);
				memcopy([out_vals], olddata, oldcap * sizeof irval);
			}
			[[out_vals] # [out_vals_count]] = [inner_vals # j];
			[out_vals_count] = [out_vals_count] + 1;
		}
	}
};
