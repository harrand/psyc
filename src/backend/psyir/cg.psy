cg_global_variable : func(var : variable mut? -> v0)
{
	glob ::= irg mut
	{
		.data := var->compile_time_storage;
	};
	if(glob.data.known != (valknown.compile_time))
	{
		glob.data = zero_as_val(var->type, zero);
	}
	var->cg = valruntime{.cg := irv_globref(ir_add_glob(glob));};
};

cg_local_variable : func(var : variable mut?, fn : function mut? -> v0)
{
	if(ty_has_qual(var->type, tyqual.qual_static))
	{
		s_decl(var, fn->scope@lexical_scope mut?);
	}
	else
	{
		// do an alloca
		decl ::= var->node->decl;
		var->cg = valruntime{.cg := ir_stack(datalayout_sizeof_ty(psyir_dl, var->type));};
	}
};

cg_function_param : func(fn : function mut?, var : variable mut?, idx : u64 -> v0)
{
};

cg_load_if_lvalue : func(v : val -> val)
{
	ret : val mut := v;
	if(v.hand == (valhand.lvalue))
	{
		ret.runtime.cg = ir_load(ret.runtime.cg, reg_for_ty(ret.type));
		ret.hand = (valhand.rvalue);
	}
	return ret;
};

cg_node : func(node : ast?, scope : lexical_scope? -> val)
{
	dbg_action(node, scope);
	if(ast_is_stmt(node, ast_stmt_tag.ret))
	{
		parent_fn ::= scope_get_parent_function(scope);
		if(parent_fn == zero)
		{
			psyc_error_begin(node->loc);
			putzstr("return statements are not allowed within the global scope");
			putchar(10);
			ast_print_annotated_source(program_find_source_file(node->loc.file)->src, node, 1, underline_colour.red);
			psyc_diag_end();
			psyc_exit_failure();
		}
		parent_retty ::= ty_unwrap(parent_fn->type)->fn.return_type;
		// return stmt.
		if(node->children_count == 0)
		{
			if(!ty_is_v0(parent_retty))
			{
				psyc_error_begin(node->loc);
				putzstr("return statement within function ");
				putchar('"');
				putbytes(parent_fn->node->function.name, parent_fn->node->function.name_len);
				putchar('"');
				putzstr(" must return a value");
				putchar(10);
				ast_print_annotated_source(program_find_source_file(node->loc.file)->src, node, 1, underline_colour.red);
				psyc_diag_end();
				psyc_exit_failure();
			}
			ir_retnone();
			return zero;
		}
		else
		{
			if(ty_is_v0(parent_retty))
			{
				psyc_error_begin(node->loc);
				putzstr("return statement within function ");
				putchar('"');
				putbytes(parent_fn->node->function.name, parent_fn->node->function.name_len);
				putchar('"');
				putzstr(" must not return anything");
				putchar(10);
				ast_print_annotated_source(program_find_source_file(node->loc.file)->src, node, 1, underline_colour.red);
				psyc_diag_end();
				psyc_exit_failure();
			}
			retval ::= val_convert_to(cg_node(ast_get_child(node, 0), scope), parent_retty, scope, val_resolution.runtime_only, node);
			ir_ret(retval.runtime.cg);
			return retval;
		}
	}
	if(ast_is_stmt(node, ast_stmt_tag.if_block))
	{
		return cg_if(node, scope);
	}
	if(ast_is_stmt(node, ast_stmt_tag.while_block))
	{
		return cg_while(node, scope);
	}
	if(ast_is_stmt(node, ast_stmt_tag.for_block))
	{
		return cg_for(node, scope);
	}	
	return val_node(node, scope, val_resolution.runtime_or_compile_time);
};

cg_if : func(node : ast?, scope : lexical_scope mut? -> val)
{
	return zero;
};

cg_while : func(node : ast?, scope : lexical_scope mut? -> val)
{
	return zero;
};

cg_for : func(node : ast?, scope : lexical_scope mut? -> val)
{
	return zero;
};
