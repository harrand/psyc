valruntime : struct
{
	cg : irv;
};
psyir_dl_val : datalayout mut := zero;
psyir_dl : datalayout? mut := zero;

valruntime_dump : func(v : valruntime -> v0)
{
	putzstr("irv()");
	tmpwriter ::= bwriter mut
	{
		.endian := native_endianness();
		.buf := zero;
		.len := zero;
		.cursor := zero;
		.ar := global_arena;
	};
	bwrite_irv_disasm(ref tmpwriter, v.cg);
	putbytes(tmpwriter.buf, tmpwriter.len);
};

cg_setup : func(-> v0)
{
	psyir_dl_val = datalayout_psy64();
	psyir_dl = ref psyir_dl_val;
};

cg_sizeof : func(type : tyid -> val)
{
	return integer_as_val(datalayout_sizeof_ty(psyir_dl, type));
};

cg_alignof : func(type : tyid -> val)
{
	return integer_as_val(datalayout_alignof_ty(psyir_dl, type));
};

codegen : func(-> v0)
{
	psyc_timed_begin(psyc_stage.codegen);

	cg_global_variables(program_scope());
	//cg_all_asms(program_scope());
	cg_all_functions(program_scope());
	psyc_timed_end();
};

cg_global_variables : func(scope : lexical_scope mut? -> v0)
{
	i : u64 mut;
	for(i = 0; i < (scope->variables_count); i = i + 1)
	{
		glob ::= scope->variables # i;
		if(ty_has_qual(glob->type, tyqual.qual_static))
		{
			s_decl(glob, scope);
		}
		else
		{
			cg_global_variable(scope->variables # i);
		}
	}
};

cg_all_functions : func(scope : lexical_scope mut? -> v0)
{
	i : u64 mut;
	for(i = 0; i < (scope->functions_count); i = i + 1)
	{
		cg_func_sig(scope->functions # i, zero);
	}
	for(i = 0; i < (scope->functions_count); i = i + 1)
	{
		cg_func_def(scope->functions # i);
	}
};

reg_for_ty : func(type : tyid -> ir_reg)
{
	retsz_bits ::= datalayout_sizeof_ty(psyir_dl, type) * 8;
	retreg : ir_reg mut;
	if(ty_is_floating_point(type))
	{
		if(retsz_bits <= 32)
		{
			retreg = ir_reg.f;
		}
		else
		{
			retreg = ir_reg.ff;
		}
	}
	else
	{
		retreg = ir_reg.b;
		if(retsz_bits > 8)
		{
			retreg = ir_reg.w;
		}
		if(retsz_bits > 16)
		{
			retreg = ir_reg.d;
		}
		if(retsz_bits > 32)
		{
			retreg = ir_reg.q;
		}
		if(retsz_bits > 64)
		{
			retreg = ir_reg.x;
		}
		if(retsz_bits > 128)
		{
			retreg = ir_reg.y;
		}
		if(retsz_bits > 256)
		{
			retreg = ir_reg.z;
		}
	}
	return retreg;
};

cg_func_sig : func(fn : function mut?, name : u8? -> v0)
{
	lnk_name : u8? mut := name;
	lnk_name_len : u64 mut;
	if(lnk_name == zero)
	{
		lnk_name = fn->name;
		lnk_name_len = fn->name_len;
	}
	else
	{
		lnk_name_len = zstrlen(lnk_name);
	}
	
	fnt ::= ty_unwrap(fn->type)->fn;
	fn_retty ::= fnt.return_type;
	retreg : ir_reg mut := reg_for_ty(fn_retty);

	default_callconv ::= irf_callconv.sysv;
	fn->cg = valruntime{.cg := irv_fnref(ir_add_func(lnk_name, lnk_name_len, retreg, default_callconv));};
	i : u64 mut;
	for(i = 0; i < fnt.params_count; i = i + 1)
	{
		ir_add_param(reg_for_ty([fnt.param_types # i]));
	}
};

cg_func_def : func(fn : function mut? -> v0)
{
	ir_setpos(irpos_from_fnref(fn->cg.cg));
	funcscope ::= fn->scope@lexical_scope mut?;
	dbg_declare_function(fn);
	i : u64 mut;
	for(i = 0; i < (funcscope->variables_count); i = i + 1)
	{
		func_var ::= funcscope->variables # i;
		if(func_var->param_idx == -1)
		{
			cg_local_variable(func_var, fn);
		}
		else
		{
			cg_function_param(fn, func_var, i);
		}
	}

	for(i = 1; i < (fn->node->children_count); i = i + 1)
	{
		impl_child ::= ast_get_child(fn->node, i);
		cg_node(impl_child, funcscope);
	}

	last_child ::= ast_get_last_child_if_ret(fn->node);
	if(last_child == zero)
	{
		// if we return void then just add a retvoid here
		// otherwise, error out because we must end with a return.
		if(ty_is_v0(ty_unwrap(fn->type)->fn.return_type))
		{
			ir_retnone();
		}
	}
};

