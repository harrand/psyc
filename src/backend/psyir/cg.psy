cg_funcref : func(fn : function? -> val)
{
	return val
	{
		.tag := valtag.typed_value;
		.known := valknown.runtime;
		.hand := valhand.rvalue;
		.type := fn->type;
		.compile_time := zero;
		.runtime := valruntime{.cg := fn->cg.cg;};
	};
};

