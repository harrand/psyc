cg_call : func(callee : val mut, params : val?, scope : lexical_scope mut?, source : ast? -> val)
{
	callee = cg_load_if_lvalue(callee);
	i : u64 mut;
	fty ::= ty_unwrap(callee.type)->fn;
	param_cgs : irv mut? := alloca(fty.params_count * sizeof irv);
	for(i = 0; i < (fty.params_count); i = i + 1)
	{
		[param_cgs # i] = (cg_load_if_lvalue(val_dynamic([params # i], scope, source)).runtime.cg);
	}
	if(ty_is_bad(fty.return_type))
	{
		ir_call(irpos_from_fnref(callee.runtime.cg), param_cgs, fty.params_count);
		return zero;
	}
	return val
	{
		.tag := valtag.typed_value;
		.known := valknown.runtime;
		.hand := valhand.rvalue;
		.type := fty.return_type;
		.compile_time := zero;
		.runtime := valruntime
		{
			// this cg_type might want false for ref_function_types
			.cg := ir_rcall(irpos_from_fnref(callee.runtime.cg), param_cgs, fty.params_count);
		};
	};
};

