irpos_from_fnref : func(fnref : irv -> irpos)
{
	return irpos{.func_cursor := fnref.v1; .blk_cursor := 0;};
};

ir_call : func(callee : irpos, params : irv?, params_count : u64 -> v0)
{
	fn ::= ir_get_fn(callee);
	if(params_count != fn->params_count)
	{
		psyc_panic_begin(zero);
		putzstr("ir function ");
		putchar('"');
		putbytes(fn->name, fn->name_len);
		putchar('"');
		putzstr(" expects ");
		putuint(fn->params_count);
		putzstr(" but was given ");
		putuint(params_count);
		psyc_diag_end();
		psyc_exit_failure();
	}

	inst ::= iri mut
	{
		.tag := iri_tag.call;
		.operands := irv[4]
		{
			.0 := irv_fnref(callee);
			... := zero;
		};
		... := zero;
	};

	i : u64 mut;
	for(i = 0; i < params_count; i = i + 1)
	{
		iri_add_operand(ref inst, [params # i]);
	}

	ir_add_instruction(inst);
};

ir_rcall : func(callee : irpos, params : irv?, params_count : u64 -> irv)
{
	fn ::= ir_get_fn(callee);
	if(params_count != fn->params_count)
	{
		psyc_panic_begin(zero);
		putzstr("ir function ");
		putchar('"');
		putbytes(fn->name, fn->name_len);
		putchar('"');
		putzstr(" expects ");
		putuint(fn->params_count);
		putzstr(" but was given ");
		putuint(params_count);
		psyc_diag_end();
		psyc_exit_failure();
	}

	out : irv mut := zero;
	if(fn->ret != zero)
	{
		out = ir_new_reg(fn->ret);
	}

	inst ::= iri mut
	{
		.tag := iri_tag.rcall;
		.operands := irv[4]
		{
			.0 := out;
			.1 := irv_fnref(callee);
			... := zero;
		};
		... := zero;
	};

	i : u64 mut;
	for(i = 0; i < params_count; i = i + 1)
	{
		iri_add_operand(ref inst, [params # i]);
	}

	ir_add_instruction(inst);
	return out;
};

