// composite instructions (common functionality that are easily expressed using other instructions but are not themselves instructions)
ir_bitwise_not : func(op : irv -> irv)
{
	out ::= ir_new_reg(irv_size(op));
	ir_add_instruction(iri
	{
		.tag := iri_tag.xor;
		.operands := irv[4]
		{
			.0 := out;
			.1 := op;
			.2 := irv_imm(-1, irv_size(op));
			... := zero;
		};
		... := zero;
	});
	return out;
};

ir_logical_not : func(op : irv -> irv)
{
	out ::= ir_new_reg(irv_size(op));
	ir_add_instruction(iri
	{
		.tag := iri_tag.cmp_eq;
		.operands := irv[4]
		{
			.0 := out;
			.1 := op;
			.2 := irv_imm(0, irv_size(op));
			... := zero;
		};
		... := zero;
	});
	return out;
};
