x64inst_tag : enum
{
	.nop := 0;
	.mov := 1;
	.movsx := 2;
	.movzx := 3;
	.movd := 4;
	.movq := 5;
	.movss := 6;
	.movsd := 7;
	.push := 8;
	.pop := 9;
	.cbw := 10;
	.cwde := 11;
	.cdqe := 12;
	.cwd := 13;
	.cdq := 14;
	.cqo := 15;
	.inc := 16;
	.dec := 17;
	.neg := 18;
	.not := 19;

	.lea := 20;
	.add := 21;
	.sub := 22;
	.mul := 23;
	.imul := 24;
	.div := 25;
	.idiv := 26;
	.xor := 27;
	.or := 28;
	.and := 29;

	.shl := 30;
	.sar := 31;
	.shr := 32;
	
	.call := 33;
	.jmp := 34; // jump unconditional
	.jz := 35; // jump if zero/equal
	.jnz := 36; // jump if not zero/equal
	.jl := 37; // jump if signed less (less)
	.jle := 38; // jump if signed less or equal
	.jg := 39; // jump if signed greater (greater)
	.jge := 40; // jump if signed greater or equal
	.jb := 41; // jump if unsigned less (below)
	.jbe := 42; // jump if unsigned less or equal
	.ja := 43; // jump if unsigned greater (above)
	.jae := 44; // jump if unsigned greater or equal
	.js := 45; // jump if sign bit set (i.e negativity)
	.jo := 46; // jump if overflow bit set (wrap-around is based so we ignore this)

	.test := 47;
	.cmp := 48;
	.setz := 49;
	.setnz := 50;
	.setl := 51;
	.setle := 52;
	.setg := 53;
	.setge := 54;
	.setb := 55;
	.setbe := 56;
	.seta := 57;
	.setae := 58;
	.sets := 59;
	.seto := 60;

	.ret := 61;
	.setz := 62;
	.cvtsi2ss := 63;
	.cvtsi2sd := 64;
	.cvttss2si := 65;
	.cvttsd2si := 66;
	.addss := 67;
	.addsd := 68;
	.subss := 69;
	.subsd := 70;
	.mulss := 71;
	.mulsd := 72;
	.divss := 73;
	.divsd := 74;
	.movaps := 75;
	.movapd := 76;
	.movdqa := 77;
	.movups := 78;
	.movupd := 79;
	.movdqu := 80;
	.syscall := 81;
	.int3 := 82;

	.custom := 83;
};

x64inst : struct
{
	tag : x64inst_tag;
	operands : x64val mut[4];
	// implementation detail. represents some byte offset in an encoder where this instruction begins
	enc_byte_offset_begin : u64;
	enc_byte_offset_end : u64;
};

x64inst_operands_count : func(inst : x64inst mut? -> u64)
{
	i : u64 mut;
	for(i = 0; i < sizeof typeof(inst->operands); i = i + 1)
	{
		if(!x64val_is_valid(inst->operands # i))
		{
			return i;
		}
	}
	return i;
};

x64inst_is_any_custom : func(inst : x64inst mut? -> bool)
{
	return inst->tag@s64 >= x64inst_tag.custom@s64;
};

x64inst_name ::= u8?[countof x64inst_tag]
{
	.0 := "nop\0";
	.1 := "mov\0";
	.2 := "movsx\0";
