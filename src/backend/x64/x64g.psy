// global data
x64g : struct
{
	size : u64;
	init_data : u8? weak;
	init_data_size : u64;
};

x64g_equal : func(lhs : x64g, rhs : x64g -> bool)
{
	// x64gs are equal if:
	// they are the same size and have the same init data
	if(lhs.size != rhs.size)
	{
		return false;
	}
	if(lhs.init_data_size != rhs.init_data_size)
	{
		return false;
	}
	i : u64 mut;
	for(i = 0; i < lhs.init_data_size; i = i + 1)
	{
		if([lhs.init_data # i] != [rhs.init_data # i])
		{
			return false;
		}
	}
	return true;
};
