x64enc_fetch_lea : func(w : bwriter mut?, inst : x64inst mut? -> x64enc_table_entry mut?)
{
	return encoding_tbl_lea # 0;
};

x64enc_fetch_add : func(w : bwriter mut?, inst : x64inst mut? -> x64enc_table_entry mut?)
{
	op1 ::= inst->operands # 1;
	if((op1->tag == x64val_tag.imm) && ([x64val_imm_get_size(op1)] == 64))
	{
		panic_begin();
		putzstr("immediate operand to ADD is 64-bit, which is unencodeable\0");
		panic_end();
	}
	return encoding_tbl_add # x64enc_access_encoding_tbl_2op(inst);
};

x64enc_fetch_sub : func(w : bwriter mut?, inst : x64inst mut? -> x64enc_table_entry mut?)
{
	op1 ::= inst->operands # 1;
	if((op1->tag == x64val_tag.imm) && ([x64val_imm_get_size(op1)] == 64))
	{
