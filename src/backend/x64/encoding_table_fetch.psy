};

x64enc_fetch_shl : func(w : bwriter mut?, inst : x64inst mut? -> x64enc_table_entry mut?)
{
	op1 ::= inst->operands # 1;
	if(x64val_get_size(op1) != 8)
	{
		panic_begin();
		putzstr("rhs operand to SHL must always be 8-bit\0");
		panic_end();
	}
	if(op1->tag == x64val_tag.reg)
	{
		if([x64val_reg_get_reg(op1)] != x64_reg.rcx)
		{
			panic_begin();
			putzstr("register rhs operand to SHL must always be CL\0");
			panic_end();
		}
	}
	return encoding_tbl_shl # x64enc_access_encoding_tbl_bitshift(inst);
};

x64enc_fetch_sar : func(w : bwriter mut?, inst : x64inst mut? -> x64enc_table_entry mut?)
{
	op1 ::= inst->operands # 1;
	if(x64val_get_size(op1) != 8)
	{
		panic_begin();
		putzstr("rhs operand to SAR must always be 8-bit\0");
		panic_end();
	}
	if(op1->tag == x64val_tag.reg)
	{
		if([x64val_reg_get_reg(op1)] != x64_reg.rcx)
		{
			panic_begin();
			putzstr("register rhs operand to SAR must always be CL\0");
			panic_end();
		}
	}
	return encoding_tbl_sar # x64enc_access_encoding_tbl_bitshift(inst);
};

x64enc_fetch_shr : func(w : bwriter mut?, inst : x64inst mut? -> x64enc_table_entry mut?)
{
	op1 ::= inst->operands # 1;
	if(x64val_get_size(op1) != 8)
	{
		panic_begin();
		putzstr("rhs operand to SHR must always be 8-bit\0");
		panic_end();
	}
	if(op1->tag == x64val_tag.reg)
	{
		if([x64val_reg_get_reg(op1)] != x64_reg.rcx)
		{
			panic_begin();
			putzstr("register rhs operand to SHR must always be CL\0");
			panic_end();
		}
	}
	return encoding_tbl_shr # x64enc_access_encoding_tbl_bitshift(inst);
};

x64enc_fetch_call : func(w : bwriter mut?, inst : x64inst mut? -> x64enc_table_entry mut?)
{
	op0 ::= inst->operands # 0;
	if(op0->tag == x64val_tag.memreg)
	{
		if([x64val_memreg_get_base(op0)] == x64_reg.rip)
		{
			if(x64val_get_size(op0) != 32)
			{
				panic_begin();
				putzstr("riprel operand to CALL must be 32-bit\0");
				panic_end();
			}
			return encoding_tbl_call # 0;
		}
	}
	if(x64val_get_size(op0) != 64)
	{
		panic_begin();
		putzstr("r/m operand to CALL must be 64-bit");
		panic_end();
	}
	return encoding_tbl_call # 1;
};

