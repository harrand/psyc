x64enc_fetch_inc : func(w : bwriter mut?, inst : x64inst mut? -> x64enc_table_entry mut?)
{
	return encoding_tbl_inc # x64enc_access_encoding_tbl_1op(inst);
};

x64enc_fetch_dec : func(w : bwriter mut?, inst : x64inst mut? -> x64enc_table_entry mut?)
