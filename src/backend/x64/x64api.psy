x64_register_custom_value_type : func(idx : u64, bwrite_fn : func(w : bwriter mut?, v : x64v -> v0), size_fn : func(v : x64v -> u64), setsize_fn : func(v : x64v mut?, newsz : u64 -> v0) -> v0)
{
	[tbl_customval_handler_funcs # idx] = bwrite_fn;
	[tbl_customval_size_funcs # idx] = size_fn;
	[tbl_customval_setsize_funcs # idx] = setsize_fn;
};
