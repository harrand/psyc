// call a r/m64 or ripreladdr procedure
x64_call : func(callee : x64v -> v0)
{
	if(x64v_is_riprel(callee))
	{
		if(x64v_size(callee) != 32)
		{
			panic_assert_failure("call riprel only supports rel32");
		}
	}
	else
	{
		if(x64v_size(callee) != 64)
		{
			panic_assert_failure("call r/m only supports r/m64");
		}
	}
	x64_add_instruction(x64i
	{
		.tag := x64i_tag.call;
		.operands := x64v[4]
		{
			.0 := callee;
			... := zero;
		};
	});
};

