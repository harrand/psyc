};

// mov 128-bits worth of doubles from r/m 128 src to r/m 128 dst
// there is no alignment requirement. movapd is faster but has a 16 byte alignment requirement for memory operands
x64_movupd : func(dst : x64v, src : x64v -> v0)
{
	x64_add_instruction(x64i
	{
