x64_getfn : func(-> u64)
{
	return x64api.func_cursor;
};

x64_setfn : func(pos : u64 -> v0)
{
	x64api.func_cursor = pos;
};

x64_add_instruction : func(inst : x64i -> u64)
{
	fn ::= x64api.prog.funcs # (x64api.func_cursor);
	if(fn->inst == zero)
	{
		fn->inst_cap = 8;
		fn->inst = arena_alloc(global_arena, fn->inst_cap * sizeof x64i);
	}
	while(fn->inst_count >= fn->inst_cap)
	{
		oldcap ::= fn->inst_cap;
		old ::= fn->inst;
		fn->inst_cap = (fn->inst_cap * 2);
		fn->inst = arena_alloc(global_arena, fn->inst_cap * sizeof x64i);
		memcopy(fn->inst, old, oldcap * sizeof x64i);
	}
	idx ::= fn->inst_count;
	fn->inst_count = (fn->inst_count + 1);
	[fn->inst # idx] = inst;
	return idx;
};

x64_dump_disasm_to : func(w : bwriter mut? -> v0)
{
	bwrite_x64p_disasm(w, x64api.prog);
};

x64_dump_to_stdout : func(-> v0)
{
	tmp ::= bwriter mut
	{
		.endian := native_endianness();
		.buf := zero;
		.len := zero;
		.cursor := zero;
		.ar := global_arena;
	};
	x64_dump_disasm_to(ref tmp);
	putbytes(tmp.buf, tmp.len);
};

// instructions api
x64_nop : func(-> v0)
{
	x64_add_instruction(x64i
	{
		.tag := x64i_tag.nop;
		.operands := zero;
	});
};

x64_mov : func(dst : x64v, src : x64v -> v0)
{
	if(x64v_is_imm(src) && (x64v_size(src) == 64))
	{
		if(!x64v_is_reg(dst) || (x64v_size(dst) != 64))
		{
			panic_assert_failure("mov: 64-bit immediates are only supported if the destination is an r64");
		}
	}
	if(!x64v_is_imm(src) && (x64v_size(src) != x64v_size(dst)))
	{
		panic_assert_failure("dst and src of mov instruction were not of the same size. this is not allowed unless the src is an imm32 and the dst is 64-bit");
	}
	x64_add_instruction(x64i
	{
		.tag := x64i_tag.mov;
		.operands := x64v[4]
		{
			.0 := dst;
			.1 := src;
			... := zero;
		};
	});
};

x64_movsx : func(dst : x64v, src : x64v -> v0)
{
	if(x64v_size(dst) <= x64v_size(src))
	{
		panic_assert_failure("dst of movsx must be greater than the src");
	}
	x64_add_instruction(x64i
	{
		.tag := x64i_tag.movsx;
		.operands := x64v[4]
		{
			.0 := dst;
			.1 := src;
			... := zero;
		};
	});
};

x64_movzx : func(dst : x64v, src : x64v -> v0)
{
	if(x64v_size(dst) <= x64v_size(src))
	{
		panic_assert_failure("dst of movsx must be greater than the src");
	}
	x64_add_instruction(x64i
	{
		.tag := x64i_tag.movzx;
		.operands := x64v[4]
		{
			.0 := dst;
			.1 := src;
			... := zero;
		};
	});
};

x64_movd : func(dst : x64v, src : x64v -> v0)
{
	// r/m32 or xmm in any order
	total ::= x64v_size(dst) + x64v_size(src);
	if(total != (32 + 128))
	{
		panic_assert_failure("total operand size of movd should be 32 + 128");
	}
	// todo: check r/m32 and r128
	x64_add_instruction(x64i
	{
		.tag := x64i_tag.movd;
		.operands := x64v[4]
		{
			.0 := dst;
			.1 := src;
			... := zero;
		};
	});
};

x64_movq : func(dst : x64v, src : x64v -> v0)
{
	// r/m64 or xmm in any order
	total ::= x64v_size(dst) + x64v_size(src);
	if(total != (64 + 128))
	{
		panic_assert_failure("total operand size of movd should be 64 + 128");
	}
	// todo: check r/m64 and r128
	x64_add_instruction(x64i
	{
		.tag := x64i_tag.movq;
		.operands := x64v[4]
		{
			.0 := dst;
			.1 := src;
			... := zero;
		};
	});
};

