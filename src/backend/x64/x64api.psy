// mov 128-bits worth of floats from r/m 128 src to r/m 128 dst
// memory operands *must* be 16 byte aligned. use movups for a slower version that has no such requirement.
x64_movaps : func(dst : x64v, src : x64v -> v0)
{
	x64_add_instruction(x64i
	{
		.tag := x64i_tag.movaps;
		.operands := x64v[4]
		{
			.0 := dst;
			.1 := src;
			... := zero;
		};
	});
};

// mov 128-bits worth of doubles from r/m 128 src to r/m 128 dst
// memory operands *must* be 16 byte aligned. use movupd for a slower version that has no such requirement.
x64_movapd : func(dst : x64v, src : x64v -> v0)
{
	x64_add_instruction(x64i
	{
		.tag := x64i_tag.movapd;
		.operands := x64v[4]
		{
			.0 := dst;
			.1 := src;
			... := zero;
		};
	});
};

// mov 128-bits worth of integers from r/m 128 src to r/m 128 dst
// memory operands *must* be 16 byte aligned. use movdqu for a slower version that has no such requirement.
x64_movdqa : func(dst : x64v, src : x64v -> v0)
{
	x64_add_instruction(x64i
	{
		.tag := x64i_tag.movdqa;
		.operands := x64v[4]
		{
			.0 := dst;
			.1 := src;
			... := zero;
		};
	});
};

// mov 128-bits worth of floats from r/m 128 src to r/m 128 dst
// there is no alignment requirement. movaps is faster but has a 16 byte alignment requirement for memory operands
x64_movups : func(dst : x64v, src : x64v -> v0)
{
	x64_add_instruction(x64i
	{
		.tag := x64i_tag.movups;
		.operands := x64v[4]
		{
