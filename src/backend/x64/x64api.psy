x64api_t : struct
{
	prog : x64p mut;
	func_cursor : u64;
};

x64api : x64api_t mut := zero;

x64_add_func : func(-> x64v)
{
	if(x64api.prog.funcs == zero)
	{
		x64api.prog.funcs_cap = 8;
		x64api.prog.funcs = arena_alloc(global_arena, x64api.prog.funcs_cap * sizeof x64f);
	}
	while(x64api.prog.funcs_count >= x64api.prog.funcs_cap)
	{
		oldcap ::= x64api.prog.funcs_cap;
		old ::= x64api.prog.funcs;
		x64api.prog.funcs_cap = (x64api.prog.funcs_cap * 2);
		x64api.prog.funcs = arena_alloc(global_arena, x64api.prog.funcs_cap * sizeof x64f);
		memcopy(x64api.prog.funcs, old, oldcap * sizeof x64f);
	}
	idx ::= x64api.prog.funcs_count;
	x64api.prog.funcs_count = (x64api.prog.funcs_count + 1);
	[x64api.prog.funcs # idx] = x64f
	{
		... := zero;
	};
	x64_setfn(idx);
	return x64v_fn(idx);
};

x64_set_entrypoint : func(funcref : x64v -> v0)
{
	x64api.prog.entrypoint_func = x64v_fn_get_idx(funcref);
};

x64_current_fn : func(-> x64f mut?)
{
	return x64api.prog.funcs # x64api.func_cursor;
};

x64_current_instruction_id : func(-> u64)
{
	return x64_current_fn()->inst_count;
};

x64_add_rodata : func(g : x64g -> u64)
{
	if(x64api.prog.rodata == zero)
	{
		x64api.prog.rodata_cap = 8;
		x64api.prog.rodata = arena_alloc(global_arena, x64api.prog.rodata_cap * sizeof x64g);
	}
	while(x64api.prog.rodata_count >= x64api.prog.rodata_cap)
	{
		oldcap ::= x64api.prog.rodata_cap;
		old ::= x64api.prog.rodata;
		x64api.prog.rodata_cap = (x64api.prog.rodata_cap * 2);
		x64api.prog.rodata = arena_alloc(global_arena, x64api.prog.rodata_cap * sizeof x64g);
		memcopy(x64api.prog.rodata, old, oldcap * sizeof x64g);
	}
	idx ::= x64api.prog.rodata_count;
	x64api.prog.rodata_count = (x64api.prog.rodata_count + 1);
	[x64api.prog.rodata # idx] = g;
	return idx;
};

