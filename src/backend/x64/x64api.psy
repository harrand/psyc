// add imm/r/m 8/16/32/64 (src) to r/m 8/16/32/64 (dst) and store the result in dst
x64_add : func(dst : x64v, src : x64v -> v0)
{
	if(x64v_is_imm(src) && (x64v_size(src) == 64))
	{
		panic_assert_failure("add does not support 64-bit immediates");
	}
	x64_add_instruction(x64i
	{
		.tag := x64i_tag.add;
		.operands := x64v[4]
		{
			.0 := dst;
			.1 := src;
			... := zero;
		};
	});
};

