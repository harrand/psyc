x64glob_tag : enum
{
	// readonly data aka 'rodata'
	.readonly := 0;
	// mutable (read + write) data 'data'
	.mutable := 1;
	// mutable (read + write) data (zeroed) aka 'bss'
	.mutablezero := 2;
};

x64glob : struct
{
	tag : x64glob_tag;
	size : u64;
	init_data : u8? weak;
	init_data_size : u64;
};
