x64_parse : func(code : u8?, code_len : u64, constraint : u8?, constraint_len : u64 -> v0)
{
	codelex : lex_state mut := zero;
	(codelex.tokens_cap) = 1024;
	(codelex.tokens) = arena_alloc(global_arena, sizeof typeof([codelex.tokens]) * (codelex.tokens_cap));
	codelex.path = zero;
	codelex.src = code;
	while(codelex.cursor < code_len)
	{
		lex_next(ref codelex);
	}
	// todo: parse the assembly tokens
};
