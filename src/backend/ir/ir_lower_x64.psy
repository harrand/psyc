ir_shl_lower_x64 : func(inst : irinst mut?, fn : irfunc mut? -> v0)
{
	// must be same size
	out ::= [ir_shl_get_out(inst)];
	outx64 ::= irval_lower_x64v(out);

	lhs ::= [ir_shl_get_lhs(inst)];
	lhsx64 ::= irval_lower_x64v(lhs);
	rhs ::= [ir_shl_get_rhs(inst)];
	rhsx64 : x64v mut := irval_lower_x64v(rhs);

	// if rhs is not an immediate, then it must be moved into CL and thats used instead
	// bitshifting instructions only allow imm or CL as the rhs.
	x64_mov(outx64, lhsx64);
	if(rhs.tag != irval_tag.imm)
	{
		cl ::= x64v_reg(x64_reg.rcx, 8);
		x64_mov(cl, rhsx64);
		rhsx64 = cl;
	}
	x64_shl(outx64, rhsx64);
};

