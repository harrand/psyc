irabi : enum
{
	.psy64 := 0;
};

irabi_chunk : func(abi : irabi, tys : ty?, tys_count : u64, out_chunks : irchunk mut? mut?, out_chunks_count : u64 mut? -> v0)
{
	[irabi_chunk_tbl # (abi@s64)](tys, tys_count, out_chunks, out_chunks_count);
};


irabi_chunk_tbl ::= func(tys : ty?, tys_count : u64, out_chunks : irchunk mut? mut?, out_chunks_count : u64 mut? -> v0)[countof irabi]
{
	.0 := irabi_chunk_psy64;
};
