lower_x64_custom_value_types : func(-> v0)
{
	x64_register_custom_value_type(lower_x64_custom_x64v_tag_vreg, bwrite_lower_x64_custom_vreg, lower_x64_custom_vreg_get_size, lower_x64_custom_vreg_set_size);
	x64_register_custom_value_type(lower_x64_custom_x64v_tag_vmemreg, bwrite_lower_x64_custom_vmemreg, lower_x64_custom_vmemreg_get_size, lower_x64_custom_vmemreg_set_size);
	x64_register_custom_value_type(lower_x64_custom_x64v_tag_irblk, bwrite_lower_x64_custom_irblk, lower_x64_custom_irblk_get_size, lower_x64_custom_irblk_set_size);
};

// generic irval -> x64v lowering function
lower_x64_irval : func(v : irval -> x64v)
{
	if(v.tag == irval_tag.reg)
	{
		if(v.r1 == irsz.global_variable)
		{
			glob ::= ir_ref_glob(v);
			// figure out if it is rodata, data or bss
			lower_type ::= lower_x64_irglob_usrdata_get_type(glob->usrdata);
			lower_x64_idx ::= lower_x64_irglob_usrdata_get_x64_idx(glob->usrdata);
			if(lower_type == lower_x64_globtype.rodata)
			{
				return x64v_rodata(lower_x64_idx, 0, glob->size);
			}
			if(lower_type == lower_x64_globtype.data)
			{
				return x64v_data(lower_x64_idx, 0, glob->size);
			}
			if(lower_type == lower_x64_globtype.bss)
			{
				return x64v_bss(lower_x64_idx, 0, glob->size);
			}
		}
		return lower_x64_custom_vreg(v);
	}
	if(v.tag == irval_tag.funcref)
	{
		return x64v_fn(irval_funcref_get_idx(v));
	}
	if(v.tag == irval_tag.blkref)
	{
		return lower_x64_custom_irblk(irpos{.func_cursor := x64api.func_cursor; .blk_cursor := irval_blkref_get_idx(v);});
	}
	if(v.tag == irval_tag.asmref)
	{
		// NOT SURE
	}
	if(v.tag == irval_tag.imm)
	{
		return x64v_imm(irval_imm_get_value(v), irsz_size_bytes(irval_imm_get_irsz(v)) * 8);
	}
	return zero;
};

bwrite_colour_red : func(w : bwriter mut? -> v0)
{
	bwrite8(w, 27);
	bwrite_zstr(w, "[91m");
};

bwrite_colour_yellow : func(w : bwriter mut? -> v0)
{
	bwrite8(w, 27);
	bwrite_zstr(w, "[93m");
};

bwrite_colour_blue : func(w : bwriter mut? -> v0)
{
	bwrite8(w, 27);
	bwrite_zstr(w, "[94m");
};

bwrite_colour_reset : func(w : bwriter mut? -> v0)
{
	bwrite8(w, 27);
	bwrite_zstr(w, "[0m");
};

// custom x64v

lower_x64_custom_x64v_tag_vreg ::= 0;

lower_x64_custom_vreg : func(ir_reg : irval -> x64v)
{
	custom_idx : s64 mut := x64v_tag.custom0@s64;
	return x64v
	{
		.tag := (custom_idx + lower_x64_custom_x64v_tag_vreg)@x64v_tag;
		.v1 := irval_get_irsz(ir_reg)@s64@_;
		.v2 := irval_reg_get_index(ir_reg);
	};
};

lower_x64_value_is_vreg : func(v : x64v -> bool)
{
	custom_idx : s64 mut := x64v_tag.custom0@s64;
	return v.tag == ((custom_idx + lower_x64_custom_x64v_tag_vreg)@x64v_tag);
};

bwrite_lower_x64_custom_vreg : func(w : bwriter mut?, v : x64v -> v0)
{
	ret : u64 mut := 0;
	sz ::= v.v1@s64@irsz;
	bwrite_colour_blue(w);
	bwrite_zstr(w, enumname(sz));
	bwrite_uint(w, v.v2);
	bwrite_colour_reset(w);
};

lower_x64_custom_vreg_get_irsz : func(v : x64v -> irsz)
{
	return v.v1@s64@irsz;
};

lower_x64_custom_vreg_get_size : func(v : x64v -> u64)
{
	return irsz_size_bytes(lower_x64_custom_vreg_get_irsz(v)) * 8;
};

lower_x64_custom_vreg_set_size : func(v : x64v mut?, newsz : u64 -> v0)
{
	is_fp ::= irsz_is_floating_point(v->v1@s64@irsz);
	if(newsz == 8)
	{
		v->v1 = (irsz.b@s64@u64);
	}
	if(newsz == 16)
	{
		v->v1 = (irsz.w@s64@u64);
	}
	if(newsz == 32)
	{
		if(is_fp)
		{
			v->v1 = (irsz.f@s64@u64);
		}
		else
		{
			v->v1 = (irsz.d@s64@u64);
		}
	}
	if(newsz == 64)
	{
		if(is_fp)
		{
			v->v1 = (irsz.ff@s64@u64);
		}
		else
		{
			v->v1 = (irsz.q@s64@u64);
		}
	}
	if(newsz == 128)
	{
		v->v1 = (irsz.x@s64@u64);
	}
	if(newsz == 256)
	{
		v->v1 = (irsz.y@s64@u64);
	}
	if(newsz == 512)
	{
		v->v1 = (irsz.z@s64@u64);
	}
};

lower_x64_custom_vreg_get_index : func(v : x64v -> u64)
{
	return v.v2;
};

lower_x64_custom_x64v_tag_vmemreg ::= 1;

lower_x64_custom_vmemreg : func(outsz : irsz, base_reg : irval, index_reg : irval, scale : irval, disp : irval -> x64v)
{
	custom_idx : s64 mut := x64v_tag.custom0@s64;
	return x64v
	{
		.tag := (custom_idx + lower_x64_custom_x64v_tag_vmemreg)@x64v_tag;
		.v1 := outsz@s64@_;
		.v2 := irval_get_irsz(base_reg)@s64@_;
		.v3 := irval_reg_get_index(base_reg);
		.v4 := irval_get_irsz(index_reg)@s64@_;
		.v5 := irval_reg_get_index(index_reg);
		.v6 := irval_imm_get_value(scale);
		.v7 := irval_imm_get_value(disp);
	};
};

lower_x64_value_is_vmemreg : func(v : x64v -> bool)
{
	custom_idx : s64 mut := x64v_tag.custom0@s64;
	return v.tag == ((custom_idx + lower_x64_custom_x64v_tag_vmemreg)@x64v_tag);
};

bwrite_lower_x64_custom_vmemreg : func(w : bwriter mut?, v : x64v -> v0)
{
	ret : u64 mut := 0;
	out_sz ::= irsz_size_bytes(v.v1@s64@irsz) * 8;
	mem_size_log2 ::= log2(out_sz) - 3;

	base ::= lower_x64_custom_vmemreg_get_base(v);
	index ::= lower_x64_custom_vmemreg_get_index(v);
	scale ::= lower_x64_custom_vmemreg_get_scale(v);
	disp ::= lower_x64_custom_vmemreg_get_disp(v);

	bwrite_colour_blue(w);
	bwrite_zstr(w, [tbl_memptrnames # mem_size_log2]);
	bwrite_zstr(w, " [");
	// print unless: base.tag == zero or (base.tag == reg and irsz == 0)
	// aka if (base.tag != zero && !(base.tag == reg and irsz == 0))
	if((base.tag != zero) && !((base.tag == irval_tag.reg) && (irval_reg_get_irsz(base) == zero)))
	{
		bwrite_irval_reg(w, lower_x64_custom_vmemreg_get_base(v));
	}
	if((index.tag != zero) && !((index.tag == irval_tag.reg) && (irval_reg_get_irsz(index) == zero)))
	{
		bwrite_zstr(w, " + ");
		bwrite_irval_reg(w, lower_x64_custom_vmemreg_get_index(v));
		if(scale != 1)
		{
			bwrite_zstr(w, " * ");
			bwrite_uint(w, scale);
		}
	}
	if(disp != 0)
	{
		bwrite_zstr(w, " + ");
		bwrite_uint(w, disp);
	}
	bwrite_zstr(w, "]");
	bwrite_colour_reset(w);
};

lower_x64_custom_vmemreg_get_irsz : func(v : x64v -> irsz)
{
	return v.v1@s64@irsz;
};

lower_x64_custom_vmemreg_get_size : func(v : x64v -> u64)
{
	return irsz_size_bytes(lower_x64_custom_vmemreg_get_irsz(v)) * 8;
};

lower_x64_custom_vmemreg_set_size : func(v : x64v mut?, newsz : u64 -> v0)
{
	is_fp ::= irsz_is_floating_point(lower_x64_custom_vmemreg_get_irsz([v]));
	if(newsz == 8)
	{
		v->v1 = (irsz.b@s64@u64);
	}
	if(newsz == 16)
	{
		v->v1 = (irsz.w@s64@u64);
	}
	if(newsz == 32)
	{
		if(is_fp)
		{
			v->v1 = (irsz.f@s64@u64);
		}
		else
		{
			v->v1 = (irsz.d@s64@u64);
		}
	}
	if(newsz == 64)
	{
		if(is_fp)
		{
			v->v1 = (irsz.ff@s64@u64);
		}
		else
		{
			v->v1 = (irsz.q@s64@u64);
		}
	}
	if(newsz == 128)
	{
		v->v1 = (irsz.x@s64@u64);
	}
	if(newsz == 256)
	{
		v->v1 = (irsz.y@s64@u64);
	}
	if(newsz == 512)
	{
		v->v1 = (irsz.z@s64@u64);
	}
};

lower_x64_custom_vmemreg_get_base : func(v : x64v -> irval)
{
	return irval_reg(v.v2@s64@irsz, v.v3);
};

lower_x64_custom_vmemreg_get_index : func(v : x64v -> irval)
{
	return irval_reg(v.v4@s64@irsz, v.v5);
};

lower_x64_custom_vmemreg_get_scale : func(v : x64v -> u64)
{
	return v.v6;
};

lower_x64_custom_vmemreg_get_disp : func(v : x64v -> u64)
{
	return v.v7;
};

lower_x64_custom_x64v_tag_irblk ::= 2;

lower_x64_custom_irblk : func(pos : irpos -> x64v)
{
	custom_idx : s64 mut := x64v_tag.custom0@s64;
	return x64v
	{
		.tag := (custom_idx + lower_x64_custom_x64v_tag_irblk)@x64v_tag;
		.v1 := pos.func_cursor;
		.v2 := pos.blk_cursor;
	};
};

bwrite_lower_x64_custom_irblk : func(w : bwriter mut?, v : x64v -> v0)
{
	bwrite_colour_blue(w);
	bwrite8(w, '_');
	bwrite_uint(w, lower_x64_custom_irblk_get_blk_cursor(v));
	bwrite_colour_reset(w);
};

lower_x64_custom_irblk_get_blk_cursor : func(v : x64v -> u64)
{
	return v.v2;
};

lower_x64_custom_irblk_get_size : func(v : x64v -> u64)
{
	// 32-bit ripreli
	return 32;
};

lower_x64_custom_irblk_set_size : func(v : x64v mut?, newsz : u64 -> v0)
{
	// todo: error out.
};

lower_x64_value_is_irblk : func(v : x64v -> bool)
{
	custom_idx : s64 mut := x64v_tag.custom0@s64;
	return v.tag == ((custom_idx + lower_x64_custom_x64v_tag_irblk)@x64v_tag);
};

