irval_tag : enum
{
	.reg := 1;
	.glob := 2;
	.fnref := 3;
	.blkref := 4;
};

irval : struct
{
	tag : irval_tag;
	v1 : u64;
	v2 : u64;
	v3 : u64;
};

irval_reg : func(idx : u64, type : tyid -> irval)
{
	return irval
	{
		.tag := irval_tag.reg;
		.v1 := type@s64@u64;
		.v2 := idx;
	};
};

irval_reg_get_type : func(reg : irval -> tyid)
{
	return reg.v1@s64@tyid;
};

irval_reg_get_idx : func(reg : irval -> u64)
{
	return reg.v2;
};
