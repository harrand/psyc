codegen_ir : func(-> v0)
{
	i : u64 mut;
	for(i = 0; i < prog.global_scope.funcs_count; i = i + 1)
	{
		codegen_ir_func(prog.global_scope.funcs # i);
	}

	if(args_should_dump_ir())
	{
		irprog_dump(ref(irapi.prog));
	}
};

codegen_ir_func : func(fn : function_t mut? -> v0)
{
	myself : irval mut;
	irfn ::= ir_add_func(ref myself);
	// todo: chunking for ir_add_param and ir_add_return calls

	fn->irfunc_idx = irfn->idx;
};
