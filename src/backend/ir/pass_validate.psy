ir_pass_validate : func(-> v0)
{
	i : u64 mut;
	for(i = 0; i < irapi.prog.funcs_count; i = i + 1)
	{
		irfunc_validate(irapi.prog.funcs # i);
	}
};

irfunc_validate : func(fn : irfunc mut? -> v0)
{
	i : u64 mut;
	for(i = 0; i < fn->blks_count; i = i + 1)
	{
		irblk_validate(fn, fn->blks # i);
	}
};

irblk_validate : func(fn : irfunc mut?, blk : irblk mut? -> v0)
{
	if(blk->insts_count == 0)
	{
		psyc_error_begin(zero);
		putzstr("function ");
		putuint(fn->idx);
		putzstr(", block ");
		putuint(blk->idx);
		putzstr(" contains zero instructions");
		psyc_diag_end();
		psyc_exit_failure();
	}
	i : u64 mut;
	inst : irinst mut;
	for(i = 0; i < blk->insts_count; i = i + 1)
	{
		inst = [blk->insts # i];
		if(i == (blk->insts_count - 1))
		{
			if(!irinst_is_terminator(inst))
			{
				psyc_error_begin(zero);
				putzstr("function ");
				putuint(fn->idx);
				putzstr(", block ");
				putuint(blk->idx);
				putzstr(" does not end with a terminating instruction (jmp/jmpif/ret)");
				psyc_diag_end();
				psyc_exit_failure();
			}
		}
		else
		{
			if(irinst_is_terminator(inst))
			{
				psyc_error_begin(zero);
				putzstr("function ");
				putuint(fn->idx);
				putzstr(", block ");
				putuint(blk->idx);
				putzstr(" contains a terminator that is not the last instruction in the block");
				psyc_diag_end();
				psyc_exit_failure();
			}
		}
	}
};
