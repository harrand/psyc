lower_x64_irblk : func(fn : irfunc mut?, blk : irblk mut? -> v0)
{
	i : u64 mut;

	blkid_x64 ::= x64v_imm(blk->idx, 64);
	x64_add_custom_instruction(x64_custom_inst_blkbegin, ref blkid_x64, 1);
	for(i = 0; i < blk->insts_count; i = i + 1)
	{
		lower_x64_irinst(blk->insts # i, fn);
	}
	x64_add_custom_instruction(x64_custom_inst_blkend, ref blkid_x64, 1);
};
