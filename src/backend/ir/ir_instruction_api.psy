	return ir_cmp_generic(irinst_tag.cmp_fgt, lhs, rhs);
};

ir_cmp_fge : func(lhs : irval, rhs : irval -> irval)
{
	return ir_cmp_generic(irinst_tag.cmp_fge, lhs, rhs);
};

ir_call : func(callee : irval, params : irval mut?, params_count : u64, returns_sz : irsz mut?, returns_out : irval mut?, returns_count : u64 -> v0)
{
	inst ::= irinst mut
	{
		.tag := irinst_tag.call;
		.operands := typeof(irinst{}.operands)
		{
			.0 := irval_qimm(returns_count);
			... := zero;
		};
		... := zero;
	};

	i : u64 mut;
	for(i = 0; i < returns_count; i = i + 1)
	{
		[returns_out # i] = ir_new_reg_of([returns_sz # i]);
		irinst_add_operand(ref inst, [returns_out # i]);
	}
	irinst_add_operand(ref inst, callee);
	for(i = 0; i < params_count; i = i + 1)
	{
		irinst_add_operand(ref inst, [params # i]);
	}

	ir_add_instruction(inst);
};

ir_call_get_callee : func(call : irinst mut? -> irval mut?)
{
	return irinst_get_operand([call], ir_call_get_returns_count(call) + 1);
};

ir_call_get_returns_count : func(call : irinst mut? -> u64)
{
	return irval_imm_get_value([irinst_get_operand([call], 0)]);
};

ir_call_get_return : func(call : irinst mut?, idx : u64 -> irval mut?)
{
	return irinst_get_operand([call], 1 + idx);
};

ir_call_get_params_count : func(call : irinst mut? -> u64)
{
	returns_count ::= irval_imm_get_value([irinst_get_operand([call], 0)]);
	return irinst_operands_count([call]) - (returns_count + 2);
};

ir_call_get_param : func(call : irinst mut?, idx : u64 -> irval mut?)
{
	returns_count ::= irval_imm_get_value([irinst_get_operand([call], 0)]);
	return irinst_get_operand([call], returns_count + 2 + idx);
};

ir_call_fn : func(callee : irpos, params : irval mut?, params_count : u64, returns_out : irval mut? -> v0)
{
	fnref ::= irval_funcref(callee);
	fn ::= ir_ref_func(fnref);
	ir_call(fnref, params, params_count, fn->returns, returns_out, fn->returns_count);
};

ir_call_asm : func(callee : irval, params : irval mut?, params_count : u64 -> irval)
{
	as ::= ir_ref_asm(callee);
	out : irval mut;
	if(as->ret == zero)
	{
		ir_call(callee, params, params_count, zero, zero, 0);
	}
	else
	{
		ir_call(callee, params, params_count, ref(as->ret), ref out, 1);
	}
	return out;
};

ir_brk : func(-> v0)
{
	ir_add_instruction(irinst
	{
		.tag := irinst_tag.brk;
		.operands := zero;
		... := zero;
	});
};

ir_unreachable : func(-> v0)
{
	ir_add_instruction(irinst
	{
		.tag := irinst_tag.unreachable;
		.operands := zero;
		... := zero;
	});
};
