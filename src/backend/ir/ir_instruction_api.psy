ir_stack : func(size : irval, align : irval -> irval)
{
	ptrout ::= ir_new_reg_of(irsz_ptr);
	fn ::= ir_current_func();
	fn->stack_amt = (fn->stack_amt + irval_imm_get_value(size));
	ir_add_instruction(irinst
	{
		.tag := irinst_tag.stack;
		.operands := typeof(irinst{}.operands)
		{
			.0 := ptrout;
			.1 := size;
			.2 := align;
			... := zero;
		};
		... := zero;
	});
	return ptrout;
};

ir_stack_get_ptr : func(inst : irinst mut? -> irval mut?)
{
	return irinst_get_operand([inst], 0);
};

ir_stack_get_size : func(inst : irinst mut? -> irval mut?)
{
	return irinst_get_operand([inst], 1);
};

ir_stack_get_align : func(inst : irinst mut? -> irval mut?)
{
	return irinst_get_operand([inst], 2);
};

ir_load : func(outsz : irsz, base : irval, index : irval, scale : irval, disp : irval -> irval)
{
	// outreg = load base + (index * scale)
	// very similar to a memory operand. everything but 'base' is optional
	out ::= ir_new_reg_of(outsz);
	ir_add_instruction(irinst
	{
		.tag := irinst_tag.load;
		.operands := typeof(irinst{}.operands)
		{
			.0 := out;
			.1 := irval_or_null(base);
			.2 := irval_or_null(index);
			.3 := irval_or_null(scale);
			.4 := irval_or_null(disp);
			... := zero;
		};
		... := zero;
	});
	return out;
};

ir_load_get_out : func(inst : irinst mut? -> irval mut?)
{
	return irinst_get_operand([inst], 0);
};

ir_load_get_base : func(inst : irinst mut? -> irval mut?)
{
	return irinst_get_operand([inst], 1);
};

ir_load_get_index : func(inst : irinst mut? -> irval mut?)
{
	return irinst_get_operand([inst], 2);
};

ir_load_get_scale : func(inst : irinst mut? -> irval mut?)
{
	return irinst_get_operand([inst], 3);
};

ir_load_get_disp : func(inst : irinst mut? -> irval mut?)
{
	return irinst_get_operand([inst], 4);
};

ir_store : func(v : irval, base : irval, index : irval, scale : irval, disp : irval -> v0)
{
	// store v into [base + (index * scale)]
	// very similar to a memory operand. everything but 'base' is optional
	ir_add_instruction(irinst
	{
		.tag := irinst_tag.store;
		.operands := typeof(irinst{}.operands)
		{
			.0 := v;
			.1 := irval_or_null(base);
			.2 := irval_or_null(index);
			.3 := irval_or_null(scale);
			.4 := irval_or_null(disp);
			... := zero;
		};
		... := zero;
	});
};

ir_store_get_value : func(inst : irinst mut? -> irval mut?)
{
	return irinst_get_operand([inst], 0);
};

ir_store_get_base : func(inst : irinst mut? -> irval mut?)
{
	return irinst_get_operand([inst], 1);
};

ir_store_get_index : func(inst : irinst mut? -> irval mut?)
{
	return irinst_get_operand([inst], 2);
};

ir_store_get_scale : func(inst : irinst mut? -> irval mut?)
{
	return irinst_get_operand([inst], 3);
};

ir_store_get_disp : func(inst : irinst mut? -> irval mut?)
{
	return irinst_get_operand([inst], 4);
};

ir_ret : func(retvals : irval mut?, retvals_count : u64 -> v0)
{
	inst ::= irinst mut
	{
		.tag := irinst_tag.ret;
		... := zero;
	};
	i : u64 mut;
	for(i = 0; i < retvals_count; i = i + 1)
	{
		irinst_add_operand(ref inst, [retvals # i]);
	}
	ir_add_instruction(inst);
};

ir_ret_get_count : func(inst : irinst mut? -> u64)
{
	return irinst_operands_count([inst]);
};

ir_ret_get_value : func(inst : irinst mut?, idx : u64 -> irval mut?)
{
	return irinst_get_operand([inst], 0 + idx);
};

ir_ret0 : func(-> v0)
{
	ir_ret(zero, zero);
};

ir_ret1 : func(r1 : irval -> v0)
{
	ir_ret(ref r1, 1);
};

ir_ret2 : func(r1 : irval, r2 : irval -> v0)
{
	arr ::= irval[2]{.0 := r1; .1 := r2;};
	ir_ret(arr # 0, countof typeof(arr));
};

ir_ret3 : func(r1 : irval, r2 : irval, r3 : irval -> v0)
{
	arr ::= irval[3]{.0 := r1; .1 := r2; .2 := r3;};
	ir_ret(arr # 0, countof typeof(arr));
};

ir_ret4 : func(r1 : irval, r2 : irval, r3 : irval, r4 : irval -> v0)
{
	arr ::= irval[4]{.0 := r1; .1 := r2; .2 := r3; .3 := r4;};
	ir_ret(arr # 0, countof typeof(arr));
};

ir_jmp : func(blk : irpos -> v0)
{
	inst ::= irinst mut
	{
		.tag := irinst_tag.jmp;
		.operands := typeof(irinst{}.operands)
		{
			.0 := irval_blkref(blk);
			... := zero;
		};
		... := zero;
	};
	ir_add_instruction(inst);
};

ir_jmp_get_blkref : func(inst : irinst mut? -> irval mut?)
{
	return irinst_get_operand([inst], 0);
};

ir_jmp_get_param_count : func(inst : irinst mut -> u64)
{
	return irinst_operands_count(inst) - 1;
};

ir_jmp_get_param : func(inst : irinst mut?, idx : u64 -> irval mut?)
{
	return irinst_get_operand([inst], 1 + idx);
};

ir_jmpif : func(cond : irval, true_blk : irpos, false_blk : irpos -> v0)
{
	inst ::= irinst mut
	{
		.tag := irinst_tag.jmpif;
		.operands := typeof(irinst{}.operands)
		{
			.0 := cond;
			.1 := irval_blkref(true_blk);
			.2 := irval_blkref(false_blk);
			... := zero;
		};
		... := zero;
	};
	ir_add_instruction(inst);
};

ir_jmpif_get_cond : func(inst : irinst mut? -> irval mut?)
{
	return irinst_get_operand([inst], 0);
};

ir_jmpif_get_true_blk : func(inst : irinst mut? -> irval mut?)
{
	return irinst_get_operand([inst], 1);
};

ir_jmpif_get_false_blk : func(inst : irinst mut? -> irval mut?)
{
	return irinst_get_operand([inst], 2);
};

ir_jmpif_get_param_count : func(inst : irinst mut -> u64)
{
	return irinst_operands_count(inst) - 3;
};

ir_jmpif_get_param : func(inst : irinst mut?, idx : u64 -> irval mut?)
{
	return irinst_get_operand([inst], 3 + idx);
};

