ir_stack : func(size : irval, align : irval -> irval)
{
	ptrout ::= ir_new_reg_of(irsz_ptr);
	ir_add_instruction(irinst
	{
		.tag := irinst_tag.stack;
		.operands := typeof(irinst{}.operands)
		{
			.0 := ptrout;
			.1 := size;
			.2 := align;
			... := zero;
		};
		... := zero;
	});
	return ptrout;
};

ir_load : func(outsz : irsz, base : irval, index : irval, scale : irval, disp : irval -> irval)
{
	// outreg = load base + (index * scale) + disp
	// very similar to a memory operand. everything but 'base' is optional
	out ::= ir_new_reg_of(outsz);
	inst ::= irinst mut
	{
		.tag := irinst_tag.load;
		... := zero;
	};
	// have to add because operands individually because they likely to spill into extra_operands
	irinst_add_operand(ref inst, out);
	irinst_add_operand(ref inst, base);
	irinst_add_operand(ref inst, index);
	irinst_add_operand(ref inst, scale);
	irinst_add_operand(ref inst, disp);
	ir_add_instruction(inst);
	return out;
};

ir_store : func(v : irval, base : irval, index : irval, scale : irval, disp : irval -> v0)
{
	// outreg = load base + (index * scale) + disp
	// very similar to a memory operand. everything but 'base' is optional
	inst ::= irinst mut
	{
		.tag := irinst_tag.store;
		... := zero;
	};
	// have to add because operands individually because they likely to spill into extra_operands
	irinst_add_operand(ref inst, v);
	irinst_add_operand(ref inst, base);
	irinst_add_operand(ref inst, index);
	irinst_add_operand(ref inst, scale);
	irinst_add_operand(ref inst, disp);
	ir_add_instruction(inst);
};

ir_ret : func(retvals : irval mut?, retvals_count : u64 -> v0)
{
	inst ::= irinst mut
	{
		.tag := irinst_tag.ret;
		... := zero;
	};
	i : u64 mut;
	for(i = 0; i < retvals_count; i = i + 1)
	{
		irinst_add_operand(ref inst, [retvals # i]);
	}
	ir_add_instruction(inst);
};

ir_ret0 : func(-> v0)
{
	ir_ret(zero, zero);
};

ir_ret1 : func(r1 : irval -> v0)
{
	ir_ret(ref r1, 1);
};

ir_ret2 : func(r1 : irval, r2 : irval -> v0)
{
	arr ::= irval[2]{.0 := r1; .1 := r2;};
	ir_ret(arr # 0, countof typeof(arr));
};

ir_ret3 : func(r1 : irval, r2 : irval, r3 : irval -> v0)
{
	arr ::= irval[3]{.0 := r1; .1 := r2; .2 := r3;};
	ir_ret(arr # 0, countof typeof(arr));
};

ir_ret4 : func(r1 : irval, r2 : irval, r3 : irval, r4 : irval -> v0)
{
	arr ::= irval[4]{.0 := r1; .1 := r2; .2 := r3; .3 := r4;};
	ir_ret(arr # 0, countof typeof(arr));
};

ir_jmp : func(blk : irpos, params : irval mut?, params_count : u64 -> v0)
{
	inst ::= irinst mut
	{
		.tag := irinst_tag.jmp;
		.operands := typeof(irinst{}.operands)
		{
			.0 := irval_blkref(blk);
			... := zero;
		};
		... := zero;
	};
	i : u64 mut;
	for(i = 0; i < params_count; i = i + 1)
	{
		irinst_add_operand(ref inst, [params # i]);
	}
	ir_add_instruction(inst);
};

ir_jmp0 : func(blk : irpos -> v0)
{
	ir_jmp(blk, zero, zero);
};

ir_jmp1 : func(blk : irpos, p1 : irval -> v0)
{
	ir_jmp(blk, ref p1, 1);
};

ir_jmp2 : func(blk : irpos, p1 : irval, p2 : irval -> v0)
{
	arr ::= irval[2]{.0 := p1; .1 := p2;};
	ir_jmp(blk, arr # 0, countof typeof(arr));
};

ir_jmp3 : func(blk : irpos, p1 : irval, p2 : irval, p3 : irval -> v0)
{
	arr ::= irval[3]{.0 := p1; .1 := p2; .2 := p3;};
	ir_jmp(blk, arr # 0, countof typeof(arr));
};

ir_jmp4 : func(blk : irpos, p1 : irval, p2 : irval, p3 : irval, p4 : irval -> v0)
{
	arr ::= irval[4]{.0 := p1; .1 := p2; .2 := p3; .3 := p4;};
	ir_jmp(blk, arr # 0, countof typeof(arr));
};

ir_jmpif : func(cond : irval, true_blk : irpos, false_blk : irpos, params : irval mut?, params_count : u64 -> v0)
{
	inst ::= irinst mut
	{
		.tag := irinst_tag.jmpif;
		.operands := typeof(irinst{}.operands)
		{
			.0 := cond;
			.1 := irval_blkref(true_blk);
			.2 := irval_blkref(false_blk);
			... := zero;
		};
		... := zero;
	};
	i : u64 mut;
	for(i = 0; i < params_count; i = i + 1)
	{
		irinst_add_operand(ref inst, [params # i]);
	}
	ir_add_instruction(inst);
};

ir_jmpif0 : func(cond : irval, true_blk : irpos, false_blk : irpos -> v0)
{
	ir_jmpif(cond, true_blk, false_blk, zero, zero);
};

ir_jmpif1 : func(cond : irval, true_blk : irpos, false_blk : irpos, p1 : irval -> v0)
{
	ir_jmpif(cond, true_blk, false_blk, ref p1, 1);
};

ir_jmpif2 : func(cond : irval, true_blk : irpos, false_blk : irpos, p1 : irval, p2 : irval -> v0)
{
	arr ::= irval[2]{.0 := p1; .1 := p2;};
	ir_jmpif(cond, true_blk, false_blk, arr # 0, countof typeof(arr));
};

ir_jmpif3 : func(cond : irval, true_blk : irpos, false_blk : irpos, p1 : irval, p2 : irval, p3 : irval -> v0)
{
	arr ::= irval[3]{.0 := p1; .1 := p2; .2 := p3;};
	ir_jmpif(cond, true_blk, false_blk, arr # 0, countof typeof(arr));
};

ir_jmpif4 : func(cond : irval, true_blk : irpos, false_blk : irpos, p1 : irval, p2 : irval, p3 : irval, p4 : irval -> v0)
{
	arr ::= irval[4]{.0 := p1; .1 := p2; .2 := p3; .3 := p4;};
	ir_jmpif(cond, true_blk, false_blk, arr # 0, countof typeof(arr));
};

ir_zex : func(outsz : irsz, num : irval -> irval)
{
	out ::= ir_new_reg_of(outsz);
	ir_add_instruction(irinst
	{
		.tag := irinst_tag.zex;
		.operands := typeof(irinst{}.operands)
		{
			.0 := out;
			.1 := num;
			... := zero;
		};
		... := zero;
	});
	return out;
};

