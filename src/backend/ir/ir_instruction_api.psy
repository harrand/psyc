ir_not : func(op : irval -> irval)
{
	out ::= ir_new_reg_of(irval_get_irsz(op));
	ir_add_instruction(irinst
	{
		.tag := irinst_tag.not;
		.operands := typeof(irinst{}.operands)
		{
			.0 := out;
			.1 := op;
			... := zero;
		};
		... := zero;
	});
	return out;
};

ir_not_get_out : func(inst : irinst mut? -> irval mut?)
{
	return irinst_get_operand([inst], 0);
};

ir_not_get_op : func(inst : irinst mut? -> irval mut?)
{
	return irinst_get_operand([inst], 1);
};

ir_cmp_generic : func(tag : irinst_tag, lhs : irval, rhs : irval -> irval)
{
	out ::= ir_new_reg_of(irsz.b);
	ir_add_instruction(irinst
	{
		.tag := tag;
		.operands := typeof(irinst{}.operands)
		{
			.0 := out;
			.1 := lhs;
			.2 := rhs;
			... := zero;
		};
		... := zero;
	});
	return out;
};

