};

ir_cmp_sge : func(lhs : irval, rhs : irval -> irval)
{
	return ir_cmp_generic(irinst_tag.cmp_sge, lhs, rhs);
};

ir_cmp_ult : func(lhs : irval, rhs : irval -> irval)
{
	return ir_cmp_generic(irinst_tag.cmp_ult, lhs, rhs);
};

ir_cmp_ule : func(lhs : irval, rhs : irval -> irval)
{
	return ir_cmp_generic(irinst_tag.cmp_ule, lhs, rhs);
};

ir_cmp_ugt : func(lhs : irval, rhs : irval -> irval)
{
	return ir_cmp_generic(irinst_tag.cmp_ugt, lhs, rhs);
};

ir_cmp_uge : func(lhs : irval, rhs : irval -> irval)
{
	return ir_cmp_generic(irinst_tag.cmp_uge, lhs, rhs);
};

ir_cmp_flt : func(lhs : irval, rhs : irval -> irval)
{
	return ir_cmp_generic(irinst_tag.cmp_flt, lhs, rhs);
};

ir_cmp_fle : func(lhs : irval, rhs : irval -> irval)
{
	return ir_cmp_generic(irinst_tag.cmp_fle, lhs, rhs);
