ir_biop : func(tag : irinst_tag, lhs : irval, rhs : irval -> irval)
{
	out ::= ir_new_reg_of(irval_get_irsz(lhs));
	ir_add_instruction(irinst
	{
		.tag := tag;
		.operands := typeof(irinst{}.operands)
		{
			.0 := out;
			.1 := lhs;
			.2 := rhs;
			... := zero;
		};
		... := zero;
	});
	return out;
};

ir_add : func(lhs : irval, rhs : irval -> irval)
{
	return ir_biop(irinst_tag.add, lhs, rhs);
};

ir_sub : func(lhs : irval, rhs : irval -> irval)
{
	return ir_biop(irinst_tag.sub, lhs, rhs);
