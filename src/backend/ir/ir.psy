global_ir : irprog mut := zero;

ir_add_func : func(type : tyid -> irpos)
{
	return irprog_add_func(ref global_ir, type);
};

ir_add_glob : func(v : val -> irval)
{
	return irprog_add_glob(ref global_ir, v);
};

ir_get_glob : func(globref : irval -> irglob)
{
	return [global_ir.globs # irval_globref_get_idx(globref)];
};

bwrite_ir : func(w : bwriter mut? -> v0)
{
	bwrite_irprog(w, global_ir);
};
