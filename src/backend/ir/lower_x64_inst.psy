lower_x64_fadd : func(inst : irinst mut?, fn : irfunc mut? -> v0)
{
	// must be same size
	out ::= [ir_fadd_get_out(inst)];
	outx64 ::= lower_x64_irval(out);

	lhs ::= [ir_fadd_get_lhs(inst)];
	lhsx64 ::= lower_x64_irval_but_turn_imms_into_globals(lhs);
	rhs ::= [ir_fadd_get_rhs(inst)];
	rhsx64 ::= lower_x64_irval_but_turn_imms_into_globals(rhs);

	sz ::= irval_get_irsz(lhs);

	if(sz == irsz.f)
	{
		x64_movss(outx64, lhsx64);
		x64_addss(outx64, rhsx64);
	}
	if(sz == irsz.ff)
	{
		x64_movsd(outx64, lhsx64);
		x64_addsd(outx64, rhsx64);
	}
};

