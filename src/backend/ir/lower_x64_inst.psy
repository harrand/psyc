lower_x64_call : func(inst : irinst mut?, fn : irfunc mut? -> v0)
{
	i : u64 mut;
	// prepare params/returns
	callee ::= [ir_call_get_callee(inst)];

	params_count ::= ir_call_get_params_count(inst);
	params : x64v mut? := arena_alloc(global_arena, params_count * sizeof x64v);
	for(i = 0; i < params_count; i = i + 1)
	{
		[params # i] = lower_x64_irval([ir_call_get_param(inst, i)]);
	}

	returns_count ::= ir_call_get_returns_count(inst);
	returns : x64v mut? := arena_alloc(global_arena, returns_count * sizeof x64v);
	for(i = 0; i < returns_count; i = i + 1)
	{
		[returns # i] = lower_x64_irval([ir_call_get_return(inst, i)]);
	}

	// do the call
	if(callee.tag == irval_tag.asmref)
	{
		asmdata ::= ir_ref_asm(callee);

		inputs : x64v mut?;
		inputs_count : u64 mut;
		outputs : x64v mut?;
		outputs_count : u64 mut;
		clobbers : x64v mut?;
		clobbers_count : u64 mut;
		// save anything clobbered
		x64_parse_constraints(asmdata->constraint, asmdata->constraint_len, ref inputs, ref inputs_count, ref outputs, ref outputs_count, ref clobbers, ref clobbers_count);
		k : u64 mut;
		for(k = 0; k < clobbers_count; k = k + 1)
		{
			// insert a meta instruction, telling us that a lifetime for this register begins here
			x64_add_custom_instruction(x64_custom_inst_reg_lifetime_begin, clobbers # k, 1);
		}

		x64_parse(asmdata->code, asmdata->code_len, asmdata->constraint, asmdata->constraint_len, params, params_count, returns, returns_count);

		for(k = 0; k < clobbers_count; k = k + 1)
		{
			// insert a meta instruction, telling us that a lifetime for this register ends here
			x64_add_custom_instruction(x64_custom_inst_reg_lifetime_end, clobbers # (clobbers_count - (k + 1)), 1);
		}
	}
	if(callee.tag == irval_tag.funcref)
	{
		// respect abi here...
		// pass register params and SHIT
		callfn ::= ir_ref_func(callee);
		irabi_precall_x64(callfn->abi, params, params_count);
		x64_call(lower_x64_irval(callee));
		irabi_postcall_x64(callfn->abi, params, params_count);
	}
};

lower_x64_brk : func(inst : irinst mut?, fn : irfunc mut? -> v0)
{
	x64_int3();
};

lower_x64_unreachable : func(inst : irinst mut?, fn : irfunc mut? -> v0)
{
	x64_int3();
};

