lower_x64_cmp_eq : func(inst : irinst mut?, fn : irfunc mut? -> v0)
{
	// must be same size
	out ::= [ir_cmp_get_out(inst)];
	outx64 ::= lower_x64_irval(out);

	lhs ::= [ir_cmp_get_lhs(inst)];
	lhsx64 ::= lower_x64_irval(lhs);
	rhs ::= [ir_cmp_get_rhs(inst)];
	rhsx64 : x64v mut := lower_x64_irval(rhs);

	if((rhs.tag == irval_tag.imm) && (irval_get_irsz(rhs) == irsz.q))
	{
		// cannot cmp with imm64
		x64v_set_size(ref rhsx64, 32);
	}

	x64_cmp(lhsx64, rhsx64);
	x64_setz(outx64);
};

