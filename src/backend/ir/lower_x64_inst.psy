lower_x64_irinst : func(inst : irinst mut?, fn : irfunc mut? -> v0)
{
	inst->usrdata = x64_current_instruction_id();
	[lower_x64_irinst_fn # (inst->tag@s64)](inst, fn);
};

lower_x64_irinst_fn ::= func(inst : irinst mut?, fn : irfunc mut? -> v0)[countof irinst_tag]
{
	.0 := lower_x64_stack;
	.1 := lower_x64_load;
	.2 := lower_x64_store;
	.3 := lower_x64_ret;
	.4 := lower_x64_jmp;
	.5 := lower_x64_jmpif;
	.6 := lower_x64_zex;
	.7 := lower_x64_sex;
	.8 := lower_x64_trunc;
	.9 := lower_x64_cvtf;
	.10 := lower_x64_cvti;
	.11 := lower_x64_add;
	.12 := lower_x64_sub;
	.13 := lower_x64_umul;
	.14 := lower_x64_smul;
	.15 := lower_x64_udiv;
	.16 := lower_x64_sdiv;
	.17 := lower_x64_smod;
	.18 := lower_x64_umod;
	.19 := lower_x64_fadd;
	.20 := lower_x64_fsub;
	.21 := lower_x64_fmul;
	.22 := lower_x64_fdiv;
	.23 := lower_x64_fmod;
	.24 := lower_x64_xor;
	.25 := lower_x64_or;
	.26 := lower_x64_and;
	.27 := lower_x64_shl;
	.28 := lower_x64_ushr;
	.29 := lower_x64_sshr;
	.30 := lower_x64_cmp_eq;
	.31 := lower_x64_cmp_ne;
	.32 := lower_x64_cmp_slt;
	.33 := lower_x64_cmp_sle;
	.34 := lower_x64_cmp_sgt;
	.35 := lower_x64_cmp_sge;
	.36 := lower_x64_cmp_ult;
	.37 := lower_x64_cmp_ule;
	.38 := lower_x64_cmp_ugt;
	.39 := lower_x64_cmp_uge;
	.40 := lower_x64_cmp_flt;
	.41 := lower_x64_cmp_fle;
	.42 := lower_x64_cmp_fgt;
	.43 := lower_x64_cmp_fge;
	.44 := lower_x64_call;
	.45 := lower_x64_brk;
	.46 := lower_x64_unreachable;
	... := zero;
};

lower_x64_stack : func(inst : irinst mut?, fn : irfunc mut? -> v0)
{
	size ::= [ir_stack_get_size(inst)];
	sizex64 : x64v mut := lower_x64_irval(size);
	if((size.tag == irval_tag.imm) && (irval_get_irsz(size) == irsz.q))
	{
		// downgrade size to 32 bit
		x64v_set_size(ref sizex64, 32);
	}
	// dont worry about alignkV?
	x64_sub(x64v_reg(x64_reg.rsp, 64), sizex64);
	//x64_sub(x64v_reg(x64_reg.rsp, 64), x64v_imm(size_val, size_size_bits));
	out ::= [ir_stack_get_ptr(inst)];
	x64_mov(lower_x64_custom_vreg(out), x64v_reg(x64_reg.rsp, 64));
};

lower_x64_load : func(inst : irinst mut?, fn : irfunc mut? -> v0)
{
	out ::= [ir_load_get_out(inst)];
	sz ::= irval_get_irsz(out);
	outx64 ::= lower_x64_irval(out);

	base : irval mut := [ir_load_get_base(inst)];
	index ::= [ir_load_get_index(inst)];
	index_x64 ::= lower_x64_irval(index);
	scale ::= [ir_load_get_scale(inst)];
	disp ::= [ir_load_get_disp(inst)];

	vmemreg ::= lower_x64_custom_vmemreg(sz, base, index, scale, disp);

	if(sz == irsz.x)
	{
		x64_movdqu(outx64, vmemreg);
	}
	if(sz == irsz.f)
	{
		x64_movss(outx64, vmemreg);
	}
	if(sz == irsz.ff)
	{
		x64_movsd(outx64, vmemreg);
	}
	if((sz == irsz.q) || (sz == irsz.d) || (sz == irsz.w) || (sz == irsz.b))
	{
		x64_mov(outx64, vmemreg);
	}
};

lower_x64_store : func(inst : irinst mut?, fn : irfunc mut? -> v0)
{
	v ::= [ir_store_get_value(inst)];
	// now remember, if dst is a memreg (which a store always will be) then the src cannot be an imm64 (if we are not usingmov, then it can be an immediate at all). and src cannot ever be a memory operand either because the dst is.
	sz ::= irval_get_irsz(v);
	if((v.tag == irval_tag.imm) && (sz == irsz.q))
	{
		// downgrade to 32 bit
		v = irval_dimm(irval_imm_get_value(v));
	}
	vx64 : x64v mut := lower_x64_irval(v);

	base : irval mut := [ir_store_get_base(inst)];
	index ::= [ir_store_get_index(inst)];
	index_x64 ::= lower_x64_irval(index);
	scale ::= [ir_store_get_scale(inst)];
	disp ::= [ir_store_get_disp(inst)];

	vmemreg ::= lower_x64_custom_vmemreg(sz, base, index, scale, disp);
	// incase we need an intermediate...
	intermediate : x64v mut := x64v_reg(x64_reg.rax, 64);

	if((sz == irsz.q) || (sz == irsz.d) || (sz == irsz.w) || (sz == irsz.b))
	{
		// storing a global *into* something else means storing a pointer to it
		// i.e mov [ptr], riprel xyz
		// instead of mov [ptr], [riprel xyz]
		// we need an intermediate lea to represent that
		if(v.tag == irval_tag.globref)
		{
			// use rax as scratch
			x64_lea(x64v_reg(x64_reg.rax, 64), vx64);
			vx64 = x64v_reg(x64_reg.rax, 64);
		}
		// and just store the address in rax at the location instead.
		if(x64v_is_any_mem(vx64))
		{
			x64v_set_size(ref intermediate, x64v_size(vx64));
			x64_mov(intermediate, vx64);
			vx64 = intermediate;
		}
		x64_mov(vmemreg, vx64);
	}
	else
	{
		vx64 = lower_x64_irval_but_turn_imms_into_globals(v);
		if(x64v_is_any_mem(vx64))
		{
			x64v_set_size(ref intermediate, x64v_size(vx64));
			if((sz == irsz.x) || (sz == irsz.y) || (sz == irsz.z))
			{
				x64_movdqu(intermediate, vx64);
			}
			if(sz == irsz.f)
			{
				x64v_set_size(ref intermediate, 128);
				x64_movss(intermediate, vx64);
			}
			if(sz == irsz.ff)
			{
				x64v_set_size(ref intermediate, 128);
				x64_movsd(intermediate, vx64);
			}
			vx64 = intermediate;
		}

		if((sz == irsz.x) || (sz == irsz.y) || (sz == irsz.z))
		{
			x64_movdqu(vmemreg, vx64);
		}
		if(sz == irsz.f)
		{
			x64_movss(vmemreg, vx64);
		}
		if(sz == irsz.ff)
		{
			x64_movsd(vmemreg, vx64);
		}
	}
};

lower_x64_ret : func(inst : irinst mut?, fn : irfunc mut? -> v0)
{
	// if we are returning zero/one thing, then use a simple code path
	// todo: check abi requirements
	if(ir_ret_get_count(inst) == 1)
	{
		// todo: generic irval -> x64v conversion
		// for now only handle imm
		ret0 ::= [ir_ret_get_value(inst, 0)];
		ret0_x64 ::= lower_x64_irval(ret0);
		x64_mov(x64v_reg(x64_reg.rax, x64v_size(ret0_x64)), ret0_x64);
	}
	x64_add(x64v_reg(x64_reg.rsp, 64), x64v_imm(fn->stack_amt, 32));
	x64_ret();
};

lower_x64_jmp : func(inst : irinst mut?, fn : irfunc mut? -> v0)
{
	jmploc ::= [ir_jmp_get_blkref(inst)];
	// todo: blk params
	x64_jmp(lower_x64_irval(jmploc));
};

lower_x64_jmpif : func(inst : irinst mut?, fn : irfunc mut? -> v0)
{
	// falseblk is just continue straight on
	// trueblk is the branch
	cond ::= [ir_jmpif_get_cond(inst)];
	cond_x64 ::= lower_x64_irval(cond);
	trueblk ::= [ir_jmpif_get_true_blk(inst)];
	falseblk ::= [ir_jmpif_get_false_blk(inst)];
	x64_test(cond_x64, cond_x64);
	x64_jnz(lower_x64_irval(trueblk));
	x64_jmp(lower_x64_irval(falseblk));
};

lower_x64_zex : func(inst : irinst mut?, fn : irfunc mut? -> v0)
{
	in ::= [ir_zex_get_in(inst)];
	insz ::= irval_get_irsz(in);
	out ::= [ir_zex_get_out(inst)];
	outsz ::= irval_get_irsz(out);

	// 32 bit -> 64 bit just do a mov to the 32-bit version of out (mov eax, ecx zero extends to rcx)
	if((outsz == irsz.q) && (insz == irsz.d))
	{
		outx64 : x64v mut := lower_x64_irval(out);
		x64v_set_size(ref outx64, 32);
		x64_mov(outx64, lower_x64_irval(in));
	}
	else
	{
		// always a movzx
		x64_movzx(lower_x64_irval(out), lower_x64_irval(in));
	}
};

lower_x64_sex : func(inst : irinst mut?, fn : irfunc mut? -> v0)
{
	in ::= [ir_sex_get_in(inst)];
	insz ::= irval_get_irsz(in);
	out ::= [ir_sex_get_out(inst)];
	outsz ::= irval_get_irsz(out);

	// 32 bit -> 64 bit just do a mov to the 32-bit version of out (mov eax, ecx zero extends to rcx)
	if((outsz == irsz.q) && (insz == irsz.d))
	{
		outx64 : x64v mut := lower_x64_irval(out);
		x64v_set_size(ref outx64, 32);
		x64_mov(outx64, lower_x64_irval(in));
	}
	else
	{
		// always a movsx
		x64_movsx(lower_x64_irval(out), lower_x64_irval(in));
	}
};

lower_x64_trunc : func(inst : irinst mut?, fn : irfunc mut? -> v0)
{
	// say we have an 8 bit reg
	// movzx eax, al -> everything is zero but the bottom 8 bits
	// so you get the operand, pretend its register size is the trunc out size, and do a movzx into the 32 bit version
	// but remember movzx eax, eax is not allowed
	// so if outsz == 32 then its just a mov
	in ::= [ir_trunc_get_in(inst)];
	insz ::= irval_get_irsz(in);

	out ::= [ir_trunc_get_out(inst)];
	outsz ::= irval_get_irsz(out);

	inx64 : x64v mut := lower_x64_irval(in);
	x64v_set_size(ref inx64, irsz_size_bytes(outsz) * 8);

	outx64 : x64v mut := lower_x64_irval(out);
	x64v_set_size(ref outx64, 32);

	if(outsz == irsz.d)
	{
		x64_mov(outx64, inx64);
	}
	else
	{
		x64_movzx(outx64, inx64);
	}
};

lower_x64_cvtf : func(inst : irinst mut?, fn : irfunc mut? -> v0)
{
	in ::= [ir_trunc_get_in(inst)];
	insz ::= irval_get_irsz(in);
	// insz must be q or d. anything else requires a prior conversion.

	out ::= [ir_trunc_get_out(inst)];
	outsz ::= irval_get_irsz(out);

	if(outsz == irsz.ff)
	{
		x64_cvtsi2sd(lower_x64_irval(out), lower_x64_irval(in));
	}
	else
	{
		x64_cvtsi2ss(lower_x64_irval(out), lower_x64_irval(in));
	}
};

lower_x64_cvti : func(inst : irinst mut?, fn : irfunc mut? -> v0)
{
	in ::= [ir_trunc_get_in(inst)];
	insz ::= irval_get_irsz(in);

	out ::= [ir_trunc_get_out(inst)];
	outsz ::= irval_get_irsz(out);
	// outsz must be d or q. anything else requires a prior conversion

	if(insz == irsz.ff)
	{
		x64_cvttsd2si(lower_x64_irval(out), lower_x64_irval(in));
	}
	else
	{
		x64_cvttss2si(lower_x64_irval(out), lower_x64_irval(in));
	}
};

lower_x64_add : func(inst : irinst mut?, fn : irfunc mut? -> v0)
{
	// must be same size
	out ::= [ir_add_get_out(inst)];
	outx64 ::= lower_x64_irval(out);

	lhs ::= [ir_add_get_lhs(inst)];
	lhsx64 : x64v mut := lower_x64_irval(lhs);
	rhs ::= [ir_add_get_rhs(inst)];
	rhsx64 : x64v mut := lower_x64_irval(rhs);

	if((lhs.tag == irval_tag.imm) && (irval_get_irsz(lhs) == irsz.q))
	{
		// too large imm64 is not allowed in the intermediate mov
		x64v_set_size(ref lhsx64, 32);
	}
	if((rhs.tag == irval_tag.imm) && (irval_get_irsz(rhs) == irsz.q))
	{
		// too large imm64 is not allowed in the intermediate mov
		x64v_set_size(ref rhsx64, 32);
	}

	x64_mov(outx64, lhsx64);
	x64_add(outx64, rhsx64);
};

lower_x64_sub : func(inst : irinst mut?, fn : irfunc mut? -> v0)
{
	// must be same size
	out ::= [ir_sub_get_out(inst)];
	outx64 ::= lower_x64_irval(out);

	lhs ::= [ir_sub_get_lhs(inst)];
	lhsx64 : x64v mut := lower_x64_irval(lhs);
	rhs ::= [ir_sub_get_rhs(inst)];
	rhsx64 : x64v mut := lower_x64_irval(rhs);

	if((lhs.tag == irval_tag.imm) && (irval_get_irsz(lhs) == irsz.q))
	{
		// too large imm64 is not allowed in the intermediate mov
		x64v_set_size(ref lhsx64, 32);
	}
	if((rhs.tag == irval_tag.imm) && (irval_get_irsz(rhs) == irsz.q))
	{
		// too large imm64 is not allowed in the intermediate mov
		x64v_set_size(ref rhsx64, 32);
	}

	x64_mov(outx64, lhsx64);
	x64_sub(outx64, rhsx64);
};

lower_x64_umul : func(inst : irinst mut?, fn : irfunc mut? -> v0)
{
	// must be same size
	out ::= [ir_umul_get_out(inst)];
	outx64 ::= lower_x64_irval(out);

	lhs ::= [ir_umul_get_lhs(inst)];
	lhsx64 : x64v mut := lower_x64_irval(lhs);
	rhs ::= [ir_umul_get_rhs(inst)];
	rhsx64 : x64v mut := lower_x64_irval(rhs);

	if((lhs.tag == irval_tag.imm) && (irval_get_irsz(lhs) == irsz.q))
	{
		// too large imm64 is not allowed in the intermediate mov
		x64v_set_size(ref lhsx64, 32);
	}

	x64_mov(outx64, lhsx64);
	// mul uses implicit operands, and we dont care about overflow/wraparound checking we just discard the top bits of the larger product size. in other words, umul and smul yield the same x64
	if(rhs.tag == irval_tag.imm)
	{
		// absolutely not allowed to do that
		// must move into something temporary
		if(irval_get_irsz(rhs) == irsz.q)
		{
			// too large imm64 is not allowed in the intermediate mov
			x64v_set_size(ref rhsx64, 32);
		}
		intermediate ::= x64v_reg(x64_reg.r15, x64v_size(rhsx64));
		x64_mov(intermediate, rhsx64);
		x64_imul(outx64, intermediate);
	}
	else
	{
		x64_imul(outx64, rhsx64);
	}
};

lower_x64_smul : func(inst : irinst mut?, fn : irfunc mut? -> v0)
{
	lower_x64_umul(inst, fn);
};

lower_x64_udiv : func(inst : irinst mut?, fn : irfunc mut? -> v0)
{
	// must be same size
	out ::= [ir_udiv_get_out(inst)];
	outx64 ::= lower_x64_irval(out);

	lhs ::= [ir_udiv_get_lhs(inst)];
	lhsx64 ::= lower_x64_irval(lhs);
	rhs ::= [ir_udiv_get_rhs(inst)];
	rhsx64 : x64v mut := lower_x64_irval(rhs);

	sz ::= x64v_size(lhsx64);
	// numerator goes into xax
	// denominator stays as r/m and becomes operand
	x64_mov(x64v_reg(x64_reg.rax, sz), lhsx64);
	// todo: 8 bit divide?
	// note: cwd/cdq/cqo are sign extends, so this is probably wrong for udiv
	if(sz == 16)
	{
		x64_cwd();
	}
	if(sz == 32)
	{
		x64_cdq();
	}
	if(sz == 64)
	{
		x64_cqo();
	}
	if(rhs.tag == irval_tag.imm)
	{
		// absolutely not allowed to do that
		// must move into something temporary
		if(irval_get_irsz(rhs) == irsz.q)
		{
			// too large imm64 is not allowed in the intermediate mov
			x64v_set_size(ref rhsx64, 32);
		}
		intermediate ::= x64v_reg(x64_reg.r15, x64v_size(rhsx64));
		x64_mov(intermediate, rhsx64);
		x64_div(intermediate);
	}
	else
	{
		x64_div(rhsx64);
	}
	x64_mov(outx64, x64v_reg(x64_reg.rax, sz));
};

lower_x64_sdiv : func(inst : irinst mut?, fn : irfunc mut? -> v0)
{
	// must be same size
	out ::= [ir_udiv_get_out(inst)];
	outx64 ::= lower_x64_irval(out);

	lhs ::= [ir_udiv_get_lhs(inst)];
	lhsx64 ::= lower_x64_irval(lhs);
	rhs ::= [ir_udiv_get_rhs(inst)];
	rhsx64 ::= lower_x64_irval(rhs);

	sz ::= x64v_size(lhsx64);
	// numerator goes into xax
	// denominator stays as r/m and becomes operand
	x64_mov(x64v_reg(x64_reg.rax, sz), lhsx64);
	// todo: 8 bit divide?
	if(sz == 16)
	{
		x64_cwd();
	}
	if(sz == 32)
	{
		x64_cdq();
	}
	if(sz == 64)
	{
		x64_cqo();
	}
	if(rhs.tag == irval_tag.imm)
	{
		// absolutely not allowed to do that
		// must move into something temporary
		if(irval_get_irsz(rhs) == irsz.q)
		{
			// too large imm64 is not allowed in the intermediate mov
			x64v_set_size(ref rhsx64, 32);
		}
		intermediate ::= x64v_reg(x64_reg.r15, x64v_size(rhsx64));
		x64_mov(intermediate, rhsx64);
		x64_idiv(intermediate);
	}
	else
	{
		x64_idiv(rhsx64);
	}
	x64_mov(outx64, x64v_reg(x64_reg.rax, sz));
};

