datalayout_sizeof_ty_llvm : func(type : tyid -> u64)
{
	return LLVMABISizeOfType(LLVMGetModuleDataLayout(prog.backend.cg), cg_type(type, true));
};

datalayout_alignof_ty_llvm : func(type : tyid -> u64)
{
	return LLVMABIAlignmentOfType(LLVMGetModuleDataLayout(prog.backend.cg), cg_type(type, true))@u64;
};

datalayout_offsetof_struct_llvm : func(type : tyid, memidx : u64 -> u64)
{
	return LLVMOffsetOfElement(LLVMGetModuleDataLayout(prog.backend.cg), cg_type(type, true), memidx@u32);
};
