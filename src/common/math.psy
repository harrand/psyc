log2 : func(n_ : u64 -> u64)
{
	n : u64 mut := n_;
	result : u64 mut := 0;
	if(n >= (1 << 32))
	{
		n = (n >> 32);
		result = result + 32;
	}
	if(n >= (1 << 16))
	{
		n = (n >> 16);
		result = result + 16;
	}
	if(n >= (1 << 8))
	{
		n = (n >> 8);
		result = result + 8;
	}
	if(n >= (1 << 4))
	{
		n = (n >> 4);
		result = result + 4;
	}
	if(n >= (1 << 2))
	{
		n = (n >> 2);
		result = result + 2;
	}
	if(n >= (1 << 1))
	{
		result = result + 1;
	}
	return result;
};
