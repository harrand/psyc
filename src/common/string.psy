zstr : struct
{
	data : u8 mut? weak;
};

sstr : struct
{
	data : u8 mut? mut;
	len : u64 mut;
};

zstrlen : func(z : zstr -> u64)
{
	i : u64 mut := 0;
	while([z.data # i] != zero)
	{
		i = i + 1;
	}
	return i;
};

zstrdata : func(z : zstr -> u8 mut?)
{
	return z.data;
};

sstrlen : func(s : sstr -> u64)
{
	return s.len;
};

sstrdata : func(s : sstr -> u8 mut?)
{
	return s.data;
};

zstr2sstr : func(z : zstr -> sstr)
{
	ret : sstr mut;
	ret.data = z.data;
	ret.len = zstrlen(z);
	return ret;
};
