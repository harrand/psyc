putchars : func(chars : u8?, count : u64 -> v0)
{
	linux_write(1, chars, count);
};

putzstr : func(z : u8? -> v0)
{
	putchars(z, zstrlen(z));
};

putchar : func(c : u8 -> v0)
{
	storage : u8 := c;
	putchars(ref storage, 1);
};

putuint : func(i : u64 weak -> v0)
{
	if(i > 9)
	{
		putuint(i / 10);
	}
	digit ::= i - ((i / 10) * 10);
	putchar('0' + digit);
};

putsint : func(i : s64 weak -> v0)
{
	debugbreak();
	if(i < 0)
	{
		putchar('-');
		putuint(-i@u64);
	}
	else
	{
		putuint(i@u64);
	}
};
