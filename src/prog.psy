program_optimisation : enum
{
	.O0 := 0;
	.O1 := 1;
	.O2 := 2;
	.O3 := 3;
};

prog_t : struct
{
	stack_size : u64;
	debug_symbols : bool;
	opt : program_optimisation;
	output : sstr;
	entrypoint : sstr;
};

// whole program state
prog ::= prog_t mut
{
	// defaults are all here :)
	.stack_size := 8000000;
	.debug_symbols := false;
	.opt := program_optimisation.O0;
	.output := sstr{.data := "build/psyout\0"; .len := 12;};
	.entrypoint := sstr{.data := "main\0"; .len := 5;};
};
