== default ==
{
	//test;
};

my_epic_global ::= 5 + 69;
my_chungus_global : big_chungus := zero;

big_chungus : struct
{
	x : u64;
	z : u32;
	w : u32;
	a : f32;
	b : f64;
};

syscall1 : asm("{rax},{rdi},~{rcx},~{r11}" -> v0)
{
	syscall
};

syscall3 : asm("{rax},{rdi},{rsi},{rdx},~{rcx},~{r11}" -> v0)
{
	syscall
};

write : func(fd : u32 weak, buf : u8? weak, count : u64 -> v0)
{
	syscall3(1, fd, buf, count);
	return;
};

exit : func(code : u64 weak -> v0)
{
	syscall1(60, code);
	return;
};

double : func(x : s64 weak -> s64 weak)
{
	return x * 2;
};

getit : func(-> big_chungus)
{
	return zero;
};

main : func(x : u64, y : big_chungus -> v0)
{
	myarr : u64 mut[6];
	[myarr # 0] = 148;
	mytestval : u64 mut := zero;
	mytestval = 1;
	write(1, "h-hello there i am a cool man", 29);
	exit(double(my_epic_global + mytestval) - [myarr # 0]);
	return;
};
