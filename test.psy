== default ==
{
	//test;
};

my_epic_global ::= 5;

big_chungus : struct
{
	x : u64;
	z : u32;
	w : u32;
	a : f32;
	b : f64;
};

syscall1 : asm("{rax},{rdi},~{rcx},~{r11}" -> v0)
{
	mov rax, $0
	mov rdi, $1
	syscall
};

exit : func(code : u64 weak -> v0)
{
	syscall1(60, code);
	return;
};

main : func(x : u64, y : big_chungus -> v0)
{
	x;
	mytestval : u64 := 13 * 5;
	//mytestval : u8? := "hello";
	exit(mytestval);
	return;
};
