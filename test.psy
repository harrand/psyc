== default ==
{
	//test;
};

my_epic_global ::= 5;

big_chungus : struct
{
	x : u64;
	z : u32;
	w : u32;
	a : f32;
	b : f64;
};

exit : asm("~{rax},{rdi},~{rcx},~{r11}" -> v0)
{
	mov rax, 60
	mov rdi, $0
	syscall
};

my_func : func(x : u64, y : big_chungus -> v0)
{
	x;
	mytestval : f64 := 5@f64;
	//mytestval : u8? := "hello";
	exit(mytestval);
	return;
};
